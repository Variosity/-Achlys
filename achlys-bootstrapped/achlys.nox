/*
 * ACHLYS SELF-HOSTED COMPILER (v1.8 - THE NEWLINE BYPASS)
 * "The Mist Compiles Itself"
 * * FIXED
 * - Replaced literal '\n' with computed NL variable to force correct line breaks.
 * - Updated lex_source to handle string escaping properly (\n, \t, \").
 */

// ============================================================================
// [SECTION 1] CONSTANTS
// ============================================================================

communis TOK_EOF : int -> 0^
communis TOK_INT : int -> 1^
communis TOK_FLOAT : int -> 2^
communis TOK_STRING : int -> 3^
communis TOK_IDENT : int -> 4^
communis TOK_LET : int -> 5^
communis TOK_PRINT : int -> 6^
communis TOK_IF : int -> 7^
communis TOK_ELSE : int -> 8^
communis TOK_WHILE : int -> 9^
communis TOK_OPUS : int -> 10^
communis TOK_REDDO : int -> 11^
communis TOK_BREAK : int -> 12^
communis TOK_CONTINUE : int -> 13^
communis TOK_IMPORT : int -> 20^
communis TOK_LPAREN : int -> 21^
communis TOK_RPAREN : int -> 22^
communis TOK_LBRACE : int -> 23^
communis TOK_RBRACE : int -> 24^
communis TOK_LBRACKET : int -> 25^
communis TOK_RBRACKET : int -> 26^
communis TOK_COLON : int -> 27^
communis TOK_ARROW : int -> 28^
communis TOK_CARET : int -> 29^
communis TOK_DOT : int -> 30^
communis TOK_APPEND : int -> 31^
communis TOK_EXTRACT : int -> 32^
communis TOK_AND : int -> 33^
communis TOK_OR : int -> 34^
communis TOK_CONST : int -> 35^
communis TOK_SHARED : int -> 36^
communis TOK_OP : int -> 37^
communis TOK_COMMA : int -> 38^

communis EXPR_INT : int -> 100^
communis EXPR_FLOAT : int -> 101^
communis EXPR_STRING : int -> 102^
communis EXPR_VAR : int -> 103^
communis EXPR_LIST : int -> 104^
communis EXPR_MAP : int -> 105^
communis EXPR_BINARY : int -> 106^
communis EXPR_INDEX : int -> 107^
communis EXPR_GET : int -> 108^
communis EXPR_CALL : int -> 109^
communis EXPR_INPUT : int -> 110^
communis EXPR_READ : int -> 111^
communis EXPR_MEASURE : int -> 112^

// Statement Types (Offset by 200)
communis STMT_LET : int -> 200^
communis STMT_ASSIGN : int -> 201^
communis STMT_SET : int -> 202^
communis STMT_SET_INDEX : int -> 203^
communis STMT_APPEND : int -> 204^
communis STMT_EXTRACT : int -> 205^
communis STMT_PRINT : int -> 206^
communis STMT_IF : int -> 207^
communis STMT_WHILE : int -> 208^
communis STMT_FUNC : int -> 209^
communis STMT_RETURN : int -> 210^
communis STMT_IMPORT : int -> 211^
communis STMT_BREAK : int -> 212^
communis STMT_CONTINUE : int -> 213^
communis STMT_EXPR : int -> 214^
communis STMT_CONST : int -> 215^
communis STMT_SHARED : int -> 216^

communis VAL_INT : int -> 0^
communis VAL_FLOAT : int -> 1^
communis VAL_STRING : int -> 2^
communis VAL_LIST : int -> 3^
communis VAL_MAP : int -> 4^
communis VAL_FUNC : int -> 5^
communis VAL_VOID : int -> 6^

communis global_tokens : arr -> []^
communis p_pos : int -> 0^
communis has_error : int -> 0^
communis use_huge_lists : int -> 0^

communis str_table : arr -> []^
communis stack_map : obj -> {}^
communis stack_offset : int -> 0^
communis lbl_counter : int -> 0^
communis asm_main : str -> ""^
communis asm_funcs : str -> ""^
communis in_func : int -> 0^
communis local_vars : arr -> []^ 
communis stack_depth : int -> 0^

// ============================================================================
// [SECTION 2] UTILITY FUNCTIONS
// ============================================================================

opus int_to_str(n) {
    si (n == 0) { reddo "0"^ }
    vas out : str -> ""^
    vas is_neg : int -> 0^
    si (n < 0) { is_neg -> 1^ n -> 0 - n^ }
    dum (n > 0) {
        vas digit : int -> n % 10^
        vas c : int -> 48 + digit^
        out -> signum_ex(c) + out^
        n -> n / 10^
    }
    si (is_neg) { out -> "-" + out^ }
    reddo out^
}

opus hex_to_dec(h) {
    vas len : int -> mensura(h)^
    vas val : int -> 0^
    vas i : int -> 0^ // [FIX] Start at 0, lexer already stripped '0x'
    dum (i < len) {
        vas c : int -> codex(pars(h, i, 1))^
        val -> val * 16^
        si (c >= 48) { si (c <= 57) { val -> val + (c - 48)^ } }
        si (c >= 65) { si (c <= 70) { val -> val + (c - 55)^ } }
        si (c >= 97) { si (c <= 102) { val -> val + (c - 87)^ } }
        i -> i + 1^
    }
    reddo val^
}

opus init_constants() {
    TOK_EOF -> 0^ TOK_INT -> 1^ TOK_FLOAT -> 2^ TOK_STRING -> 3^ TOK_IDENT -> 4^
    TOK_LET -> 5^ TOK_PRINT -> 6^ TOK_IF -> 7^ TOK_ELSE -> 8^ TOK_WHILE -> 9^
    TOK_OPUS -> 10^ TOK_REDDO -> 11^ TOK_BREAK -> 12^ TOK_CONTINUE -> 13^
    TOK_IMPORT -> 20^ TOK_LPAREN -> 21^ TOK_RPAREN -> 22^ TOK_LBRACE -> 23^
    TOK_RBRACE -> 24^ TOK_LBRACKET -> 25^ TOK_RBRACKET -> 26^ TOK_COLON -> 27^
    TOK_ARROW -> 28^ TOK_CARET -> 29^ TOK_DOT -> 30^ TOK_APPEND -> 31^
    TOK_EXTRACT -> 32^ TOK_AND -> 33^ TOK_OR -> 34^ TOK_CONST -> 35^
    TOK_SHARED -> 36^ TOK_OP -> 37^ TOK_COMMA -> 38^
    
    EXPR_INT -> 0^ EXPR_FLOAT -> 1^ EXPR_STRING -> 2^ EXPR_VAR -> 3^
    EXPR_LIST -> 4^ EXPR_MAP -> 5^ EXPR_BINARY -> 6^ EXPR_INDEX -> 7^
    EXPR_GET -> 8^ EXPR_CALL -> 9^ EXPR_INPUT -> 10^ EXPR_READ -> 11^
    EXPR_MEASURE -> 12^
    
    STMT_LET -> 0^ STMT_ASSIGN -> 1^ STMT_SET -> 2^ STMT_SET_INDEX -> 3^
    STMT_APPEND -> 4^ STMT_EXTRACT -> 5^ STMT_PRINT -> 6^ STMT_IF -> 7^
    STMT_WHILE -> 8^ STMT_FUNC -> 9^ STMT_RETURN -> 10^ STMT_IMPORT -> 11^
    STMT_BREAK -> 12^ STMT_CONTINUE -> 13^ STMT_EXPR -> 14^ STMT_CONST -> 15^
    STMT_SHARED -> 16^
    
    VAL_INT -> 0^ VAL_FLOAT -> 1^ VAL_STRING -> 2^ VAL_LIST -> 3^
    VAL_MAP -> 4^ VAL_FUNC -> 5^ VAL_VOID -> 6^
}

opus is_digit(c) {
    vas code : int -> codex(c)^
    // [FIX] Use explicit nesting to avoid precedence bugs
    si (code >= 48) {
        si (code <= 57) { reddo 1^ }
    }
    reddo 0^
}

opus is_alpha(c) {
    vas code : int -> codex(c)^
    // [FIX] Explicit nesting
    si (code >= 65) {
        si (code <= 90) { reddo 1^ }
    }
    si (code >= 97) {
        si (code <= 122) { reddo 1^ }
    }
    si (c == "_") { reddo 1^ }
    reddo 0^
}

opus is_alnum(c) {
    vas code : int -> codex(c)^
    vas res : int -> 0^
    
    // Check Alpha
    si (is_alpha(c)) { res -> 1^ }
    
    // Check Digit
    si (res == 0) {
        si (is_digit(c)) { res -> 1^ }
    }
    
    // [DEBUG] Print exactly what is happening
    // scribo("  [DEBUG] is_alnum('" + c + "' / " + int_to_str(code) + ") = " + int_to_str(res))^
    
    reddo res^
}

opus is_space(c) {
    vas code : int -> codex(c)^
    // [FIX] Individual checks
    si (code == 32) { reddo 1^ } // Space
    si (code == 9)  { reddo 1^ } // Tab
    si (code == 10) { reddo 1^ } // Newline
    si (code == 13) { reddo 1^ } // CR
    reddo 0^
}

opus make_token(type, text) {
    reddo { "type": type, "text": text }^
}


opus get_str_label(txt) {
    vas i : int -> 0^
    dum (i < mensura(str_table)) {
        vas entry : obj -> str_table[i]^
        si (entry["txt"] == txt) { reddo entry["lbl"]^ }
        i -> i + 1^
    }
    vas lbl : str -> "str_" + int_to_str(mensura(str_table))^
    vas new_entry : obj -> { "txt": txt, "lbl": lbl }^
    str_table << new_entry^
    reddo lbl^
}

opus error_report(msg) {
    scribo("💀 SYNTAX ERROR: " + msg)^
    has_error -> 1^
}

opus nasm_bytes(s) {
    vas out : str -> ""^
    vas len : int -> mensura(s)^
    vas i : int -> 0^
    dum (i < len) {
        vas c : str -> pars(s, i, 1)^
        vas code : int -> codex(c)^
        out -> out + int_to_str(code) + ", "^
        i -> i + 1^
    }
    reddo out + "0"^
}

opus is_local(nm) {
    vas i : int -> 0^
    dum (i < mensura(local_vars)) {
        vas v : str -> local_vars[i]^
        si (v == nm) { reddo 1^ }
        i -> i + 1^
    }
    reddo 0^
}

opus capere_argumentum(n) {
    reddo ("mate.nox")^
}

// ============================================================================
// [SECTION 3] LEXER
// ============================================================================

opus lex_source(src) {
    use_huge_lists -> 1^
    vas tokens : arr -> []^
    use_huge_lists -> 0^ 
    
    vas len : int -> mensura(src)^
    scribo("[DEBUG] Source Length: " + int_to_str(len))^
    vas i : int -> 0^
    
    // -- Hoisted Variables --
    vas c : str -> ""^
    vas next : str -> ""^
    vas start : int -> 0^
    vas txt : str -> ""^
    vas type : int -> 0^
    vas loop_c : str -> ""^
    vas adv : int -> 0^
    
    // Flags
    vas run_cmt : int -> 0^
    vas run_blk : int -> 0^
    vas run_str : int -> 0^
    vas run_num : int -> 0^
    vas run_id : int -> 0^
    vas esc : str -> ""^
    vas lcode : int -> 0^
    vas ok : int -> 0^

    dum (i < len) {
        c -> pars(src, i, 1)^
        // [DEBUG] Uncomment to trace infinite loops
        // scribo("[LEX LOOP] i=" + int_to_str(i) + " c='" + c + "'")^
        
        // [CHAIN START]
        si (is_space(c)) { 
            i -> i + 1^ 
        } 
        aliter { 
            // [BLOCK 2: COMMENTS / OP]
            si (c == "/") {
                next -> pars(src, i+1, 1)^
                si (next == "/") {
                    run_cmt -> 1^
                    dum (run_cmt) {
                        si (i >= len) { run_cmt -> 0^ }
                        si (run_cmt) {
                            loop_c -> pars(src, i, 1)^
                            si (codex(loop_c) == 10) { run_cmt -> 0^ }
                            si (run_cmt) { i -> i + 1^ }
                        }
                    }
                } aliter { 
                    si (next == "*") {
                        i -> i + 2^
                        run_blk -> 1^
                        dum (run_blk) {
                            si (i >= len) { run_blk -> 0^ }
                            si (run_blk) {
                                si (pars(src, i, 1) == "*" et pars(src, i+1, 1) == "/") {
                                    i -> i + 2^
                                    run_blk -> 0^
                                }
                                si (run_blk) { i -> i + 1^ }
                            }
                        }
                    } aliter {
                        tokens << make_token(TOK_OP, "/")^
                        i -> i + 1^
                    }
                }
            } 
            aliter { 
                // [BLOCK 3: STRINGS]
                si (c == "\"") {
                    i -> i + 1^
                    txt -> ""^
                    run_str -> 1^
                    dum (run_str) {
                        si (i >= len) { run_str -> 0^ }
                        si (run_str) {
                            loop_c -> pars(src, i, 1)^
                            si (loop_c == "\"") { run_str -> 0^ }
                            si (run_str) {
                                si (loop_c == "\\") {
                                    i -> i + 1^
                                    esc -> pars(src, i, 1)^
                                    si (esc == "n") { txt -> txt + signum_ex(10)^ }
                                    aliter { si (esc == "t") { txt -> txt + signum_ex(9)^ }
                                    aliter { si (esc == "\"") { txt -> txt + "\""^ }
                                    aliter { si (esc == "\\") { txt -> txt + "\\"^ }
                                    aliter { txt -> txt + esc^ } } } }
                                } aliter {
                                    txt -> txt + loop_c^
                                }
                                i -> i + 1^
                            }
                        }
                    }
                    tokens << make_token(TOK_STRING, txt)^
                    i -> i + 1^
                } 
                aliter { 
                    // [BLOCK 4: NUMBERS]
                    // [BLOCK 4: NUMBERS & HEX]
                    si (is_digit(c)) {
                        start -> i^
                        vas is_hex : int -> 0^
                        
                        // 1. Check for Hex Prefix (0x or 0X)
                        si (c == "0") {
                            vas next_char : str -> pars(src, i+1, 1)^
                            si (next_char == "x") { is_hex -> 1^ }
                            si (next_char == "X") { is_hex -> 1^ }
                        }

                        // 2. Handle Hexadecimal
                        si (is_hex) {
                            i -> i + 2^ // Skip the '0x'
                            start -> i^ // Reset start to the actual hex digits
                            vas run_hex : int -> 1^
                            dum (run_hex) {
                                si (i >= len) { run_hex -> 0^ }
                                si (run_hex) {
                                    loop_c -> pars(src, i, 1)^
                                    // Hex uses 0-9 and A-F, which are all alphanumeric
                                    si (is_alnum(loop_c) == 0) { run_hex -> 0^ }
                                    si (run_hex) { i -> i + 1^ }
                                }
                            }
                            vas hex_str : str -> pars(src, start, i - start)^
                            tokens << make_token(TOK_INT, int_to_str(hex_to_dec(hex_str)))^
                        } 
                        // 3. Handle Standard Integers / Decimals
                        aliter {
                            vas run_num : int -> 1^
                            dum (run_num) {
                                si (i >= len) { run_num -> 0^ }
                                si (run_num) {
                                    loop_c -> pars(src, i, 1)^
                                    
                                    // Safe Logic Flag (Bypasses 'vel' precedence bug)
                                    vas keep : int -> 0^
                                    si (is_digit(loop_c)) { keep -> 1^ }
                                    si (loop_c == ".") { keep -> 1^ }
                                    
                                    si (keep == 0) { run_num -> 0^ }
                                    si (run_num) { i -> i + 1^ }
                                }
                            }
                            txt -> pars(src, start, i - start)^
                            tokens << make_token(TOK_INT, txt)^
                        }
                    }
                    aliter { 
                        // [BLOCK 5: IDENTIFIERS]
                        si (is_alpha(c)) {
                            start -> i^
                            run_id -> 1^
                            dum (run_id) {
                                si (i >= len) { run_id -> 0^ }
                                si (run_id) {
                                    loop_c -> pars(src, i, 1)^
                                    lcode -> codex(loop_c)^
                                    ok -> 0^
                                    si (lcode >= 48) { si (lcode <= 57) { ok -> 1^ } }
                                    si (lcode >= 65) { si (lcode <= 90) { ok -> 1^ } }
                                    si (lcode >= 97) { si (lcode <= 122) { ok -> 1^ } }
                                    si (lcode == 95) { ok -> 1^ }
                                    
                                    si (ok == 0) { run_id -> 0^ }
                                    si (run_id) { i -> i + 1^ }
                                }
                            }
                            txt -> pars(src, start, i - start)^
                            type -> 4^ 
                            si (txt == "vas") { type -> 5^ }
                            si (txt == "idea") { type -> 5^ }
                            si (txt == "umbra") { type -> 5^ }
                            si (txt == "scribo") { type -> 6^ }
                            si (txt == "monstro") { type -> 6^ }
                            si (txt == "insusurro") { type -> 6^ }
                            si (txt == "si") { type -> 7^ }
                            si (txt == "aliter") { type -> 8^ }
                            si (txt == "dum") { type -> 9^ }
                            si (txt == "opus") { type -> 10^ }
                            si (txt == "reddo") { type -> 11^ }
                            si (txt == "abrumpere") { type -> 12^ }
                            si (txt == "pergere") { type -> 13^ }
                            si (txt == "importare") { type -> 20^ }
                            si (txt == "constans") { type -> 35^ }
                            si (txt == "communis") { type -> 36^ }
                            si (txt == "xor") { type -> 37^ txt -> "^"^ }
                            si (txt == "et") { type -> 33^ }
                            si (txt == "vel") { type -> 34^ }
                            si (txt == "verum") { type -> 1^ txt -> "1"^ }
                            si (txt == "falsum") { type -> 1^ txt -> "0"^ }
                            tokens << make_token(type, txt)^
                        } 
                        aliter {
                            // [BLOCK 6: SYMBOLS]
                            type -> 0^
                            adv -> 1^
                            si (c == "(") { type -> TOK_LPAREN^ }
                            si (c == ")") { type -> TOK_RPAREN^ }
                            si (c == "{") { type -> TOK_LBRACE^ }
                            si (c == "}") { type -> TOK_RBRACE^ }
                            si (c == "[") { type -> TOK_LBRACKET^ }
                            si (c == "]") { type -> TOK_RBRACKET^ }
                            si (c == ":") { type -> TOK_COLON^ }
                            si (c == "^") { type -> TOK_CARET^ }
                            si (c == ".") { type -> TOK_DOT^ }
                            si (c == ",") { type -> TOK_COMMA^ }
                            
                            si (type == 0) {
                                type -> TOK_OP^
                                next -> pars(src, i+1, 1)^
                                
                                // [FIX] Nested SI to avoid ET precedence issues
                                si (c == "-") {
                                    si (next == ">") { type -> TOK_ARROW^ c -> "->"^ adv -> 2^ }
                                }
                                si (c == "=") {
                                    si (next == "=") { c -> "=="^ adv -> 2^ }
                                }
                                si (c == "!") {
                                    si (next == "=") { c -> "!="^ adv -> 2^ }
                                }
                                // [FIX] Added <<< and >>> detection
                                si (c == "<") {
                                    vas next2 : str -> pars(src, i+2, 1)^
                                    si (next == "<") {
                                        si (next2 == "<") { type -> 37^ c -> "<<<"^ adv -> 3^ }
                                        aliter { type -> TOK_APPEND^ c -> "<<"^ adv -> 2^ }
                                    }
                                    aliter { si (next == "=") { type -> TOK_OP^ c -> "<="^ adv -> 2^ } }
                                }
                                si (c == ">") {
                                    vas next2 : str -> pars(src, i+2, 1)^
                                    si (next == ">") {
                                        si (next2 == ">") { type -> 37^ c -> ">>>"^ adv -> 3^ }
                                        aliter { type -> TOK_EXTRACT^ c -> ">>"^ adv -> 2^ }
                                    }
                                    aliter { si (next == "=") { type -> TOK_OP^ c -> ">="^ adv -> 2^ } }
                                }
                            }
                            
                            tokens << make_token(type, c)^
                            i -> i + adv^
                        }
                    }
                }
            }
        }
    }
    tokens << make_token(TOK_EOF, "EOF")^
    scribo("[DEBUG] Lexer finished. Total Tokens: " + int_to_str(mensura(tokens)))^
    reddo tokens^
}

// ============================================================================
// [SECTION 4] PARSER
// ============================================================================

opus peek() {
    si (p_pos >= mensura(global_tokens)) { reddo { "type": TOK_EOF, "text": "EOF" }^ }
    reddo global_tokens[p_pos]^
}

opus advance() { 
    vas t : obj -> peek()^
    si (t["type"] != TOK_EOF) { p_pos -> p_pos + 1^ }
    reddo t^ 
}

opus consume(type) {
    vas t : obj -> peek()^
    si (t["type"] == type) { advance()^ reddo 1^ }
    reddo 0^
}

opus expect(type) {
    si (consume(type)) { reddo 1^ }
    vas t : obj -> peek()^
    error_report("Expected token type " + int_to_str(type) + " but got " + t["text"])^
    reddo 0^
}

opus parse_primary() {
    vas t : obj -> peek()^
    si (consume(TOK_INT)) { reddo { "type": EXPR_INT, "val": t["text"] }^ }
    si (consume(TOK_STRING)) { reddo { "type": EXPR_STRING, "val": t["text"] }^ }
    
    si (consume(TOK_IDENT)) { 
        vas name : str -> t["text"]^
        si (consume(TOK_LPAREN)) {
            vas args : arr -> []^
            si (peek()["type"] != TOK_RPAREN) {
                args << parse_expr()^
                dum (consume(TOK_COMMA)) { args << parse_expr()^ }
            }
            expect(TOK_RPAREN)^
            reddo { "type": EXPR_CALL, "name": name, "args": args }^
        }
        reddo { "type": EXPR_VAR, "name": name }^ 
    }
    
    si (consume(TOK_LPAREN)) {
        vas expr : obj -> parse_expr()^
        expect(TOK_RPAREN)^
        reddo expr^
    }
    
    si (consume(TOK_LBRACKET)) {
        vas items : arr -> []^
        si (peek()["type"] != TOK_RBRACKET) {
            items << parse_expr()^
            dum (consume(TOK_COMMA)) { items << parse_expr()^ }
        }
        expect(TOK_RBRACKET)^
        reddo { "type": EXPR_LIST, "items": items }^
    }
    
    si (consume(TOK_LBRACE)) {
        vas keys : arr -> []^
        vas vals : arr -> []^
        dum (peek()["type"] != TOK_RBRACE) {
            vas k : obj -> advance()^ 
            expect(TOK_COLON)^
            vas v : obj -> parse_expr()^
            keys << k["text"]^
            vals << v^
            consume(TOK_COMMA)^
        }
        expect(TOK_RBRACE)^
        reddo { "type": EXPR_MAP, "keys": keys, "vals": vals }^
    }
    
    si (t["type"] == TOK_OP et t["text"] == "-") {
        advance()^
        vas right : obj -> parse_primary()^
        reddo { "type": EXPR_BINARY, "op": "-", "left": { "type": EXPR_INT, "val": "0" }, "right": right }^
    }

    si (t["type"] == TOK_OP et t["text"] == "!") {
        advance()^
        vas right : obj -> parse_primary()^
        reddo { "type": EXPR_BINARY, "op": "==", "left": right, "right": { "type": EXPR_INT, "val": "0" } }^
    }
    
    si (t["type"] != TOK_EOF) { advance()^ }
    error_report("Unexpected token: " + t["text"])^
    reddo { "type": EXPR_INT, "val": "0" }^
}

opus parse_postfix() {
    vas expr : obj -> parse_primary()^
    
    // [FIX] Use a manual flag instead of 'dum(1)' + 'abrumpere'
    // 'abrumpere' fails inside nested 'aliter' blocks
    vas running : int -> 1^
    
    dum (running) {
        si (consume(TOK_LBRACKET)) {
            vas idx : obj -> parse_expr()^
            expect(TOK_RBRACKET)^
            expr -> { "type": EXPR_INDEX, "obj": expr, "idx": idx }^
        } aliter {
            si (consume(TOK_DOT)) {
                vas t : obj -> advance()^
                expr -> { "type": EXPR_GET, "obj": expr, "name": t["text"] }^
            } aliter { 
                // Stop the loop manually
                running -> 0^ 
            }
        }
    }
    reddo expr^
}

opus parse_term() {
    vas left : obj -> parse_postfix()^
    vas t : obj -> peek()^
    vas running : int -> 1^
    dum (running) {
        vas is_op : int -> 0^
        si (t["type"] == TOK_OP) {
            vas op : str -> t["text"]^
            si (op == "*") { is_op -> 1^ }
            si (op == "/") { is_op -> 1^ }
            si (op == "%") { is_op -> 1^ }
        }
        si (is_op) {
            vas op : str -> t["text"]^
            advance()^
            vas right : obj -> parse_postfix()^
            left -> { "type": EXPR_BINARY, "op": op, "left": left, "right": right }^
            t -> peek()^
        } aliter { running -> 0^ }
    }
    reddo left^
}

opus parse_math() {
    vas left : obj -> parse_term()^
    vas t : obj -> peek()^
    vas running : int -> 1^
    dum (running) {
        vas is_op : int -> 0^
        si (t["type"] == TOK_OP) {
            vas op : str -> t["text"]^
            si (op == "+") { is_op -> 1^ }
            si (op == "-") { is_op -> 1^ }
        }
        si (is_op) {
            vas op : str -> t["text"]^
            advance()^
            vas right : obj -> parse_term()^
            left -> { "type": EXPR_BINARY, "op": op, "left": left, "right": right }^
            t -> peek()^
        } aliter { running -> 0^ }
    }
    reddo left^
}

opus parse_bitwise() {
    vas left : obj -> parse_math()^
    vas t : obj -> peek()^
    vas running : int -> 1^
    dum (running) {
        vas is_op : int -> 0^
        vas op : str -> t["text"]^
        si (t["type"] == TOK_OP) {
            si (op == "^") { is_op -> 1^ }
            si (op == "&") { is_op -> 1^ }
            si (op == "|") { is_op -> 1^ }
            si (op == "<<<") { is_op -> 1^ }
            si (op == ">>>") { is_op -> 1^ }
        }
        si (t["type"] == TOK_IDENT) {
            si (op == "xor") { is_op -> 1^ op -> "^"^ }
        }
        si (is_op) {
            advance()^
            vas right : obj -> parse_math()^
            left -> { "type": EXPR_BINARY, "op": op, "left": left, "right": right }^
            t -> peek()^
        } aliter { running -> 0^ }
    }
    reddo left^
}

opus parse_cmp() {
    vas left : obj -> parse_bitwise()^
    vas t : obj -> peek()^
    vas running : int -> 1^
    dum (running) {
        vas is_op : int -> 0^
        si (t["type"] == TOK_OP) {
            vas op : str -> t["text"]^
            si (op == "==") { is_op -> 1^ }
            si (op == "!=") { is_op -> 1^ }
            si (op == "<") { is_op -> 1^ }
            si (op == ">") { is_op -> 1^ }
            si (op == "<=") { is_op -> 1^ }
            si (op == ">=") { is_op -> 1^ }
        }
        si (is_op) {
            vas op : str -> t["text"]^
            advance()^
            vas right : obj -> parse_bitwise()^
            left -> { "type": EXPR_BINARY, "op": op, "left": left, "right": right }^
            t -> peek()^
        } aliter { running -> 0^ }
    }
    reddo left^
}

opus parse_expr() {
    vas left : obj -> parse_cmp()^
    vas t : obj -> peek()^
    vas running : int -> 1^
    dum (running) {
        vas is_op : int -> 0^
        si (t["type"] == TOK_AND vel t["type"] == TOK_OR) { is_op -> 1^ }
        si (is_op) {
            vas op : str -> "et"^
            si (t["type"] == TOK_OR) { op -> "vel"^ }
            advance()^
            vas right : obj -> parse_cmp()^
            left -> { "type": EXPR_BINARY, "op": op, "left": left, "right": right }^
            t -> peek()^
        } aliter { running -> 0^ }
    }
    reddo left^
}

opus parse_stmt() {
    scribo("[DEBUG] Parsing stmt...")^
    vas t : obj -> peek()^
    
    vas stmt_type : int -> -1^
    
    si (t["type"] == TOK_LET) { stmt_type -> STMT_LET^ consume(TOK_LET)^ }
    aliter { si (t["type"] == TOK_SHARED) { stmt_type -> STMT_SHARED^ consume(TOK_SHARED)^ }
    aliter { si (t["type"] == TOK_CONST) { stmt_type -> STMT_CONST^ consume(TOK_CONST)^ } } }
    
    si (stmt_type != -1) {
        vas name : obj -> advance()^
        expect(TOK_COLON)^
        advance()^
        expect(TOK_ARROW)^
        vas val : obj -> parse_expr()^
        expect(TOK_CARET)^
        reddo { "type": stmt_type, "name": name["text"], "val": val }^
    }
    
    si (consume(TOK_PRINT)) {
        expect(TOK_LPAREN)^
        vas val : obj -> parse_expr()^
        expect(TOK_RPAREN)^
        expect(TOK_CARET)^
        reddo { "type": STMT_PRINT, "val": val }^
    }
    
    si (consume(TOK_IF)) {
        expect(TOK_LPAREN)^
        vas cond : obj -> parse_expr()^
        expect(TOK_RPAREN)^
        expect(TOK_LBRACE)^
        vas body : arr -> []^
        dum (peek()["type"] != TOK_RBRACE) { body << parse_stmt()^ }
        expect(TOK_RBRACE)^
        vas else_body : arr -> []^
        si (consume(TOK_ELSE)) {
            expect(TOK_LBRACE)^
            dum (peek()["type"] != TOK_RBRACE) { else_body << parse_stmt()^ }
            expect(TOK_RBRACE)^
        }
        reddo { "type": STMT_IF, "cond": cond, "body": body, "else": else_body }^
    }
    
    si (consume(TOK_WHILE)) {
        expect(TOK_LPAREN)^
        vas cond : obj -> parse_expr()^
        expect(TOK_RPAREN)^
        expect(TOK_LBRACE)^
        vas body : arr -> []^
        dum (peek()["type"] != TOK_RBRACE) { body << parse_stmt()^ }
        expect(TOK_RBRACE)^
        reddo { "type": STMT_WHILE, "cond": cond, "body": body }^
    }
    
    si (consume(TOK_OPUS)) {
        vas name : obj -> advance()^
        expect(TOK_LPAREN)^
        vas params : arr -> []^
        si (peek()["type"] != TOK_RPAREN) {
            vas p : obj -> advance()^
            params << p["text"]^
            dum (consume(TOK_COMMA)) {
                p -> advance()^
                params << p["text"]^
            }
        }
        expect(TOK_RPAREN)^
        expect(TOK_LBRACE)^
        vas body : arr -> []^
        dum (peek()["type"] != TOK_RBRACE) { body << parse_stmt()^ }
        expect(TOK_RBRACE)^
        reddo { "type": STMT_FUNC, "name": name["text"], "params": params, "body": body }^
    }
    
    si (consume(TOK_REDDO)) {
        vas val : obj -> parse_expr()^
        expect(TOK_CARET)^
        reddo { "type": STMT_RETURN, "val": val }^
    }

    // [FIX] Loops and Multi-file Architecture
    si (consume(TOK_BREAK)) {
        expect(TOK_CARET)^
        reddo { "type": STMT_BREAK }^
    }
    si (consume(TOK_CONTINUE)) {
        expect(TOK_CARET)^
        reddo { "type": STMT_CONTINUE }^
    }
    si (consume(TOK_IMPORT)) {
        expect(TOK_LPAREN)^
        vas path : obj -> parse_expr()^
        expect(TOK_RPAREN)^
        expect(TOK_CARET)^
        reddo { "type": STMT_IMPORT, "val": path }^
    }
    
    si (t["type"] == TOK_IDENT) {
        vas next_idx : int -> p_pos + 1^
        si (next_idx >= mensura(global_tokens)) {
             error_report("Unexpected EOF")^
             reddo { "type": -1 }^
        }
        vas next : obj -> global_tokens[next_idx]^
        
        si (next["type"] == TOK_ARROW) {
            vas name : obj -> advance()^
            advance()^ 
            vas val : obj -> parse_expr()^
            expect(TOK_CARET)^
            reddo { "type": STMT_ASSIGN, "name": name["text"], "val": val }^ 
        }
        si (next["type"] == TOK_APPEND) {
            vas name : obj -> advance()^
            advance()^ 
            vas val : obj -> parse_expr()^
            expect(TOK_CARET)^
            reddo { "type": STMT_APPEND, "name": name["text"], "val": val }^
        }
        si (next["type"] == TOK_LBRACKET) {
            vas lhs : obj -> parse_expr()^
            si (consume(TOK_ARROW)) {
                vas val : obj -> parse_expr()^
                expect(TOK_CARET)^
                si (lhs["type"] == EXPR_INDEX) {
                    vas arr_nm : obj -> lhs["obj"]^
                    reddo { "type": STMT_SET_INDEX, "name": arr_nm["name"], "idx": lhs["idx"], "val": val }^
                }
            }
        }
        si (next["type"] == TOK_LPAREN) {
            vas expr : obj -> parse_expr()^
            expect(TOK_CARET)^
            reddo { "type": STMT_EXPR, "expr": expr }^
        }
    }
    
    si (t["type"] != TOK_EOF) { advance()^ }
    reddo { "type": -1 }^
}

// ============================================================================
// [SECTION 5] LLVM CODE GENERATOR (GOD MODE - FIXED)
// ============================================================================

communis reg_count : int -> 0^
communis str_count : int -> 0^
communis label_count : int -> 0^
communis out_code : str -> ""^
communis out_data : str -> ""^
communis var_map : obj -> {}^   // Locals: name -> "%ptr_name"
communis global_map : obj -> {}^ // Globals: name -> "@name"
communis loop_cond_stack : arr -> []^ // Stack for nested loops
communis loop_end_stack : arr -> []^  // Stack for nested loops

// --- HELPERS ---

opus next_reg() {
    reg_count -> reg_count + 1^
    reddo "%r" + int_to_str(reg_count)^
}

opus next_label() {
    label_count -> label_count + 1^
    reddo "L" + int_to_str(label_count)^
}

opus emit(s) {
    out_code -> out_code + "  " + s + signum_ex(10)^
}

opus emit_raw(s) {
    out_code -> out_code + s + signum_ex(10)^
}

// [SANITIZER]
opus escape_llvm(s) {
    vas out : str -> ""^
    vas len : int -> mensura(s)^
    vas i : int -> 0^
    dum (i < len) {
        vas c : str -> pars(s, i, 1)^
        si (c == "\"") { out -> out + "\\22"^ }
        aliter { si (c == "\\") { out -> out + "\\5C"^ }
        aliter { si (codex(c) == 10) { out -> out + "\\0A"^ }
        aliter { out -> out + c^ } } }
        i -> i + 1^
    }
    reddo out^
}

opus add_global_string(txt) {
    str_count -> str_count + 1^
    vas name : str -> "@.str." + int_to_str(str_count)^
    vas len : int -> mensura(txt) + 1^
    vas safe_txt : str -> escape_llvm(txt)^
    vas decl : str -> name + " = private unnamed_addr constant [" + int_to_str(len) + " x i8] c\"" + safe_txt + "\\00\", align 8" + signum_ex(10)^
    out_data -> out_data + decl^
    reddo name^
}

// --- SCOPE LOOKUP (The Fix) ---
opus get_var_ptr(name) {
    // 1. Try Local
    vas ptr : str -> var_map[name]^
    si (mensura(ptr) > 0) { reddo ptr^ }
    
    // 2. Try Global
    ptr -> global_map[name]^
    si (mensura(ptr) > 0) { reddo ptr^ }
    
    // 3. Error (Return empty, will cause crash but we can debug)
    reddo ""^
}

// --- EXPRESSION COMPILER ---

opus compile_expr(node) {
    si (node["type"] == EXPR_INT) { reddo node["val"]^ }

    si (node["type"] == EXPR_VAR) {
        vas ptr : str -> get_var_ptr(node["name"])^ 
        
        // Safety Check
        si (mensura(ptr) == 0) { 
            scribo("💀 FATAL: Undefined variable '" + node["name"] + "'")^
            reddo "0"^
        }

        vas res : str -> next_reg()^
        emit(res + " = load i64, i64* " + ptr)^
        reddo res^
    }

    si (node["type"] == EXPR_STRING) {
        vas global_ptr : str -> add_global_string(node["val"])^
        vas res : str -> next_reg()^
        vas len : int -> mensura(node["val"]) + 1^
        emit(res + " = getelementptr [" + int_to_str(len) + " x i8], [" + int_to_str(len) + " x i8]* " + global_ptr + ", i64 0, i64 0")^
        vas cast_res : str -> next_reg()^
        emit(cast_res + " = ptrtoint i8* " + res + " to i64")^
        reddo cast_res^
    }

    si (node["type"] == EXPR_BINARY) {
        vas lhs : str -> compile_expr(node["left"])^
        vas rhs : str -> compile_expr(node["right"])^
        vas op : str -> node["op"]^
        vas res : str -> next_reg()^

        vas defined : int -> 0^
        
        // [MATH & BITWISE CASCADE]
        si (op == "+") { emit(res + " = call i64 @_add(i64 " + lhs + ", i64 " + rhs + ")")^ defined -> 1^ }
        aliter { si (op == "-") { emit(res + " = sub i64 " + lhs + ", " + rhs)^ defined -> 1^ }
        aliter { si (op == "*") { emit(res + " = mul i64 " + lhs + ", " + rhs)^ defined -> 1^ }
        aliter { si (op == "/") { emit(res + " = sdiv i64 " + lhs + ", " + rhs)^ defined -> 1^ }
        aliter { si (op == "%") { emit(res + " = srem i64 " + lhs + ", " + rhs)^ defined -> 1^ }
        aliter { si (op == "&") { emit(res + " = and i64 " + lhs + ", " + rhs)^ defined -> 1^ }
        aliter { si (op == "|") { emit(res + " = or i64 " + lhs + ", " + rhs)^ defined -> 1^ }
        aliter { si (op == "^") { emit(res + " = xor i64 " + lhs + ", " + rhs)^ defined -> 1^ }
        aliter { si (op == "xor") { emit(res + " = xor i64 " + lhs + ", " + rhs)^ defined -> 1^ }
        aliter { si (op == "~") { emit(res + " = xor i64 " + lhs + ", -1")^ defined -> 1^ }
        aliter { si (op == "<<<") { emit(res + " = shl i64 " + lhs + ", " + rhs)^ defined -> 1^ }
        aliter { si (op == ">>>") { emit(res + " = lshr i64 " + lhs + ", " + rhs)^ defined -> 1^ }
        aliter { si (op == "et") { emit(res + " = and i64 " + lhs + ", " + rhs)^ defined -> 1^ }
        aliter { si (op == "vel") { emit(res + " = or i64 " + lhs + ", " + rhs)^ defined -> 1^ } } } } } } } } } } } } } }
        
        // [COMPARISONS]
        si (defined == 0) {
            si (op == "==") { 
                emit(res + " = call i64 @_eq(i64 " + lhs + ", i64 " + rhs + ")")^ 
            }
            aliter { si (op == "!=") {
                vas tmp : str -> next_reg()^
                emit(tmp + " = call i64 @_eq(i64 " + lhs + ", i64 " + rhs + ")")^
                emit(res + " = xor i64 " + tmp + ", 1")^
            }
            aliter {
                vas cmp : str -> ""^
                si (op == "<")  { cmp -> "slt"^ }
                aliter { si (op == ">")  { cmp -> "sgt"^ }
                aliter { si (op == "<=") { cmp -> "sle"^ }
                aliter { si (op == ">=") { cmp -> "sge"^ } } } }
                
                si (mensura(cmp) > 0) {
                    vas b : str -> next_reg()^
                    emit(b + " = icmp " + cmp + " i64 " + lhs + ", " + rhs)^
                    emit(res + " = zext i1 " + b + " to i64")^
                } aliter {
                    // Fallback safety
                    emit(res + " = add i64 0, 0")^
                }
            } }
        }
        reddo res^
    }

    // 5. LISTS ([1, 2, 3])
    si (node["type"] == EXPR_LIST) {
        vas res : str -> next_reg()^
        emit(res + " = call i64 @_list_new()")^
        
        vas items : arr -> node["items"]^
        vas i : int -> 0^
        dum (i < mensura(items)) {
            vas val : str -> compile_expr(items[i])^
            emit("call i64 @_list_push(i64 " + res + ", i64 " + val + ")")^
            i -> i + 1^
        }
        reddo res^
    }

    // 6. MAPS ({ "k": v })
    si (node["type"] == EXPR_MAP) {
        vas res : str -> next_reg()^
        emit(res + " = call i64 @_map_new()")^
        
        vas keys : arr -> node["keys"]^
        vas vals : arr -> node["vals"]^ // [FIX] "values" -> "vals"
        
        vas i : int -> 0^
        dum (i < mensura(keys)) {
            // Compile Key (String Literal)
            vas k : str -> keys[i]^
            vas key_ptr : str -> add_global_string(k)^
            vas key_reg : str -> next_reg()^
            vas len : int -> mensura(k) + 1^
            emit(key_reg + " = getelementptr [" + int_to_str(len) + " x i8], [" + int_to_str(len) + " x i8]* " + key_ptr + ", i64 0, i64 0")^
            vas key_int : str -> next_reg()^
            emit(key_int + " = ptrtoint i8* " + key_reg + " to i64")^
            
            // Compile Value
            vas v : obj -> vals[i]^
            vas val_reg : str -> compile_expr(v)^
            
            emit("call i64 @_map_set(i64 " + res + ", i64 " + key_int + ", i64 " + val_reg + ")")^
            i -> i + 1^
        }
        reddo res^
    }

    // 7. INDEXING & GET (list[0] or obj.prop)
    si (node["type"] == EXPR_INDEX vel node["type"] == EXPR_GET) {
        vas obj_node : obj -> {}^
        vas idx_node : obj -> {}^
        
        si (node["type"] == EXPR_INDEX) {
            obj_node -> node["obj"]^  // [FIX] "list" -> "obj"
            idx_node -> node["idx"]^  // [FIX] "index" -> "idx"
        } aliter {
            // EXPR_GET (dot notation)
            obj_node -> node["obj"]^  // [FIX] "object" -> "obj"
            // Create a temporary STRING node for the property name
            idx_node -> { "type": EXPR_STRING, "val": node["name"] }^
        }
        
        vas obj_reg : str -> compile_expr(obj_node)^
        vas idx_reg : str -> compile_expr(idx_node)^
        
        vas res : str -> next_reg()^
        emit(res + " = call i64 @_get(i64 " + obj_reg + ", i64 " + idx_reg + ")")^
        reddo res^
    }

    si (node["type"] == EXPR_CALL) {
        vas name : str -> node["name"]^
        si (name == "main") { name -> "achlys_main"^ }
        si (name == "sys") { name -> "imperium"^ }

        // [FIX] OS BARE METAL PRIMITIVES
        si (name == "scrutari") {
            vas addr_reg : str -> compile_expr(node["args"][0])^
            vas ptr_reg : str -> next_reg()^
            emit(ptr_reg + " = inttoptr i64 " + addr_reg + " to ptr")^
            vas val_reg : str -> next_reg()^
            emit(val_reg + " = load i8, ptr " + ptr_reg)^
            vas mem_res : str -> next_reg()^
            emit(mem_res + " = zext i8 " + val_reg + " to i64")^
            reddo mem_res^
        }
        si (name == "mutare_mem") {
            vas addr_reg : str -> compile_expr(node["args"][0])^
            vas val_reg : str -> compile_expr(node["args"][1])^
            vas ptr_reg : str -> next_reg()^
            emit(ptr_reg + " = inttoptr i64 " + addr_reg + " to ptr")^
            vas trunc_reg : str -> next_reg()^
            emit(trunc_reg + " = trunc i64 " + val_reg + " to i8")^
            emit("store i8 " + trunc_reg + ", ptr " + ptr_reg)^
            reddo "0"^
        }

        // [OS BARE METAL SYSCALL GATEWAY]
        // Example: imperium_kernel(1, 1, text, len) // sys_write
        si (name == "imperium_kernel") {
            vas args : arr -> node["args"]^
            // Auto-fill missing arguments with 0 to prevent segfaults
            vas a0 : str -> "0"^ si (mensura(args) > 0) { a0 -> compile_expr(args[0])^ }
            vas a1 : str -> "0"^ si (mensura(args) > 1) { a1 -> compile_expr(args[1])^ }
            vas a2 : str -> "0"^ si (mensura(args) > 2) { a2 -> compile_expr(args[2])^ }
            vas a3 : str -> "0"^ si (mensura(args) > 3) { a3 -> compile_expr(args[3])^ }
            vas a4 : str -> "0"^ si (mensura(args) > 4) { a4 -> compile_expr(args[4])^ }
            vas a5 : str -> "0"^ si (mensura(args) > 5) { a5 -> compile_expr(args[5])^ }
            vas a6 : str -> "0"^ si (mensura(args) > 6) { a6 -> compile_expr(args[6])^ }
            
            vas res : str -> next_reg()^
            emit(res + " = call i64 @syscall6(i64 " + a0 + ", i64 " + a1 + ", i64 " + a2 + ", i64 " + a3 + ", i64 " + a4 + ", i64 " + a5 + ", i64 " + a6 + ")")^
            reddo res^
        }

        si (name == "capere_argumentum") {
            vas arg_idx : str -> compile_expr(node["args"][0])^
            vas res : str -> next_reg()^
            emit(res + " = call i64 @_get_argv(i64 " + arg_idx + ")")^
            reddo res^
        }
        vas args : arr -> node["args"]^
        vas arg_str : str -> ""^
        vas i : int -> 0^
        dum (i < mensura(args)) {
            vas val : str -> compile_expr(args[i])^
            arg_str -> arg_str + "i64 " + val^
            si (i < mensura(args) - 1) { arg_str -> arg_str + ", "^ }
            i -> i + 1^
        }
        vas res : str -> next_reg()^
        si (name == "scribo") {
            emit(res + " = call i64 @print_any(i64 " + arg_str + ")")^
        } aliter {
            emit(res + " = call i64 @" + name + "(" + arg_str + ")")^
        }
        reddo res^
    }
    
    reddo "0"^
}

// --- STATEMENT COMPILER ---

opus compile_stmt(node) {


    // [FIX] STATIC INLINE LINKER
    si (node["type"] == STMT_IMPORT) {
        vas path_node : obj -> node["val"]^
        si (path_node["type"] == EXPR_STRING) {
            // Compiler uses its own runtime to read the file
            vas f_src : str -> revelare(path_node["val"])^ 
            si (mensura(f_src) > 0) {
                // Save current state
                vas old_tokens : arr -> global_tokens^
                vas old_pos : int -> p_pos^
                
                // Switch context to new file
                global_tokens -> lex_source(f_src)^
                p_pos -> 0^
                vas link_stmts : arr -> []^
                
                dum (peek()["type"] != TOK_EOF) {
                    si (peek()["type"] == TOK_CARET) { advance()^ }
                    aliter { link_stmts << parse_stmt()^ }
                }
                
                // Compile the linked file into current LLVM context
                compile_block(link_stmts)^
                
                // Restore state
                global_tokens -> old_tokens^
                p_pos -> old_pos^
            } aliter {
                scribo("💀 FATAL LINKER ERROR: Could not read " + path_node["val"])^
            }
        }
    }
    si (node["type"] == STMT_LET) {
        vas val : str -> compile_expr(node["val"])^
        vas ptr : str -> var_map[node["name"]]^
        si (mensura(ptr) == 0) {
            ptr -> "%ptr_" + node["name"]^
            emit(ptr + " = alloca i64")^
            var_map[node["name"]] -> ptr^
        }
        emit("store i64 " + val + ", i64* " + ptr)^
    }

    si (node["type"] == STMT_SET_INDEX) {
        vas val : str -> compile_expr(node["val"])^
        vas idx : str -> compile_expr(node["idx"])^
        vas list_ptr : str -> get_var_ptr(node["name"])^
        
        si (mensura(list_ptr) == 0) {
             scribo("💀 FATAL: Index set on undefined variable '" + node["name"] + "'")^
        } aliter {
             // 1. Load the list handle (i64) from the variable
             vas list_reg : str -> next_reg()^
             emit(list_reg + " = load i64, i64* " + list_ptr)^
             
             // 2. Call the runtime helper to do the heavy lifting
             // We do NOT need manual getelementptr/inttoptr here because _list_set does it.
             emit("call i64 @_set(i64 " + list_reg + ", i64 " + idx + ", i64 " + val + ")")^
        }
    }

    si (node["type"] == STMT_ASSIGN) {
        vas val : str -> compile_expr(node["val"])^
        vas ptr : str -> get_var_ptr(node["name"])^
        si (mensura(ptr) == 0) { 
             scribo("💀 FATAL: Assignment to undefined variable '" + node["name"] + "'")^
        } aliter {
             emit("store i64 " + val + ", i64* " + ptr)^
        }
    }

    si (node["type"] == STMT_APPEND) {
        vas val : str -> compile_expr(node["val"])^
        vas list_ptr : str -> get_var_ptr(node["name"])^
        
        si (mensura(list_ptr) == 0) {
             scribo("💀 FATAL: Append to undefined variable '" + node["name"] + "'")^
        } aliter {
             vas list_reg : str -> next_reg()^
             emit(list_reg + " = load i64, i64* " + list_ptr)^
             
             // [FIX] Use polymorphic append to flatten lists
             emit("call i64 @_append_poly(i64 " + list_reg + ", i64 " + val + ")")^
        }
    }

    si (node["type"] == STMT_PRINT) {
        // [DEBUG] Confirm we are compiling this
        scribo("[DEBUG] Compiling STMT_PRINT")^ 
        
        vas val : str -> compile_expr(node["val"])^
        emit("call i64 @print_any(i64 " + val + ")")^
    }

    

    si (node["type"] == STMT_BREAK) {
        vas len : int -> mensura(loop_end_stack)^
        si (len > 0) {
            vas lbl : str -> loop_end_stack[len - 1]^
            emit("br label %" + lbl)^
        }
    }

    si (node["type"] == STMT_CONTINUE) {
        vas len : int -> mensura(loop_cond_stack)^
        si (len > 0) {
            vas lbl : str -> loop_cond_stack[len - 1]^
            emit("br label %" + lbl)^
        }
    }

    si (node["type"] == STMT_RETURN) {
        vas val : str -> compile_expr(node["val"])^
        emit("ret i64 " + val)^
    }
    
    si (node["type"] == STMT_EXPR) {
        compile_expr(node["expr"])^
    }

    si (node["type"] == STMT_IF) {
        vas cond : str -> compile_expr(node["cond"])^
        vas bool : str -> next_reg()^
        emit(bool + " = icmp ne i64 " + cond + ", 0")^
        vas l_then : str -> next_label()^
        vas l_else : str -> next_label()^
        vas l_end : str -> next_label()^
        emit("br i1 " + bool + ", label %" + l_then + ", label %" + l_else)^
        emit_raw(l_then + ":")^
        compile_block(node["body"])^
        emit("br label %" + l_end)^
        emit_raw(l_else + ":")^
        si (mensura(node["else"]) > 0) { compile_block(node["else"])^ }
        emit("br label %" + l_end)^
        emit_raw(l_end + ":")^
    }
    
    si (node["type"] == STMT_WHILE) {
        vas l_cond : str -> next_label()^
        vas l_body : str -> next_label()^
        vas l_end : str -> next_label()^

        // [FIX] Push labels to stack
        loop_cond_stack << l_cond^
        loop_end_stack << l_end^

        emit("br label %" + l_cond)^
        emit_raw(l_cond + ":")^
        vas cond : str -> compile_expr(node["cond"])^
        vas bool : str -> next_reg()^
        emit(bool + " = icmp ne i64 " + cond + ", 0")^
        emit("br i1 " + bool + ", label %" + l_body + ", label %" + l_end)^

        emit_raw(l_body + ":")^
        compile_block(node["body"])^
        emit("br label %" + l_cond)^
        emit_raw(l_end + ":")^
        
        // [FIX] Pop labels (Manual extraction since we don't have pop())
        vas len : int -> mensura(loop_cond_stack)^
        vas extract_dummy : str -> ""^
        
        // Remove last item from cond stack
        vas popped_cond : arr -> []^
        vas i : int -> 0^
        dum (i < len - 1) { popped_cond << loop_cond_stack[i]^ i -> i + 1^ }
        loop_cond_stack -> popped_cond^
        
        // Remove last item from end stack
        vas popped_end : arr -> []^
        i -> 0^
        dum (i < len - 1) { popped_end << loop_end_stack[i]^ i -> i + 1^ }
        loop_end_stack -> popped_end^
    }
}

opus compile_block(stmts) {
    vas i : int -> 0^
    dum (i < mensura(stmts)) { compile_stmt(stmts[i])^ i -> i + 1^ }
}

opus scan_for_vars(stmts) {
    vas i : int -> 0^
    dum (i < mensura(stmts)) {
        vas s : obj -> stmts[i]^
        
        // 1. Found a Variable Declaration? Allocate it NOW.
        si (s["type"] == STMT_LET) {
            vas nm : str -> s["name"]^
            vas ptr : str -> var_map[nm]^
            
            // Only allocate if not already allocated in this function scope
            si (mensura(ptr) == 0) {
                ptr -> "%ptr_" + nm^
                emit(ptr + " = alloca i64")^
                var_map[nm] -> ptr^
            }
        }
        
        // 2. Recurse into IF blocks (FIXED: "then" -> "body")
        si (s["type"] == STMT_IF) {
            scan_for_vars(s["body"])^  // <--- CRITICAL FIX WAS HERE
            si (mensura(s["else"]) > 0) { scan_for_vars(s["else"])^ }
        }
        
        // 3. Recurse into WHILE blocks
        si (s["type"] == STMT_WHILE) {
            scan_for_vars(s["body"])^
        }
        
        i -> i + 1^
    }
}

opus compile_func(node) {
    vas name : str -> node["name"]^
    
    // [CRITICAL FIX] Rename user 'main' to 'achlys_main'
    si (name == "main") { name -> "achlys_main"^ }

    vas header : str -> "define i64 @" + name + "("^
    vas params : arr -> node["params"]^
    vas i : int -> 0^
    
    // RESET LOCAL STATE
    var_map -> {}^ 
    reg_count -> 0^ 

    dum (i < mensura(params)) {
        header -> header + "i64 %arg_" + params[i]^
        si (i < mensura(params) - 1) { header -> header + ", "^ }
        i -> i + 1^
    }
    header -> header + ") {"^
    emit_raw(header)^
    
    // 1. ALLOCATE PARAMETERS
    i -> 0^
    dum (i < mensura(params)) {
        vas p : str -> params[i]^
        vas ptr : str -> "%ptr_" + p^
        
        emit(ptr + " = alloca i64")^
        emit("store i64 %arg_" + p + ", i64* " + ptr)^
        var_map[p] -> ptr^
        i -> i + 1^
    }

    // 2. [FIX] PRE-PASS: HOIST ALL VARIABLES TO ENTRY BLOCK
    // This defines all 'vas' variables at the top so they dominate all uses.
    scan_for_vars(node["body"])^

    // 3. COMPILE BODY
    compile_block(node["body"])^
    
    emit("ret i64 0")^
    emit_raw("}")^
}


// ============================================================================
// [SECTION 6] LLVM RUNTIME HEADERS (COMPLETE)
// ============================================================================

opus get_llvm_header() {
    vas NL : str -> signum_ex(10)^
    vas s : str -> "; ModuleID = 'achlys_kernel'" + NL^
    s -> s + "target triple = \"x86_64-pc-linux-gnu\"" + NL^ 
    
    // --- LIBC ---
    s -> s + "declare i32 @printf(i8*, ...)" + NL^
    s -> s + "declare i32 @sprintf(i8*, i8*, ...)" + NL^
    s -> s + "declare i32 @fflush(i8*)" + NL^
    s -> s + "declare i64 @malloc(i64)" + NL^
    s -> s + "declare i8* @realloc(i8*, i64)" + NL^
    s -> s + "declare i32 @getchar()" + NL^
    s -> s + "declare void @exit(i32)" + NL^
    s -> s + "declare i8* @fopen(i8*, i8*)" + NL^
    s -> s + "declare i32 @fseek(i8*, i64, i32)" + NL^
    s -> s + "declare i64 @ftell(i8*)" + NL^
    s -> s + "declare i64 @fread(i8*, i64, i64, i8*)" + NL^
    s -> s + "declare i64 @fwrite(i8*, i64, i64, i8*)" + NL^
    s -> s + "declare i32 @fclose(i8*)" + NL^

    s -> s + "declare i32 @system(i8*)" + NL^
    s -> s + "declare i32 @usleep(i32)" + NL^
    s -> s + "declare i64 @atol(i8*)" + NL^
    s -> s + "declare i8* @strtok(i8*, i8*)" + NL^

    // --- GLOBALS ---
    s -> s + "@.fmt_int = private unnamed_addr constant [5 x i8] c\"%ld\\0A\\00\", align 8" + NL^
    s -> s + "@.fmt_str = private unnamed_addr constant [4 x i8] c\"%s\\0A\\00\", align 8" + NL^
    s -> s + "@.fmt_raw_s = private unnamed_addr constant [3 x i8] c\"%s\\00\", align 8" + NL^
    s -> s + "@.fmt_raw_i = private unnamed_addr constant [4 x i8] c\"%ld\\00\", align 8" + NL^
    s -> s + "@.mode_r = private unnamed_addr constant [2 x i8] c\"r\\00\", align 8" + NL^
    s -> s + "@.mode_w = private unnamed_addr constant [2 x i8] c\"w\\00\", align 8" + NL^
    s -> s + "@.str_lst = private unnamed_addr constant [7 x i8] c\"<list>\\00\", align 8" + NL^
    s -> s + "@.str_map = private unnamed_addr constant [6 x i8] c\"<map>\\00\", align 8" + NL^
    s -> s + "@__sys_argv = global i8** null, align 8" + NL^
    s -> s + "@__sys_argc = global i32 0, align 8" + NL^
    // Notice the \" before and after the brackets
    s -> s + "@.m_brk_l = private unnamed_addr constant [2 x i8] c\"[\\00\", align 8" + NL^
    s -> s + "@.m_brk_r = private unnamed_addr constant [3 x i8] c\"]\\0A\\00\", align 8" + NL^
    s -> s + "@.m_comma = private unnamed_addr constant [3 x i8] c\", \\00\", align 8" + NL^

    // --- RUNTIME HELPERS (FIXED: Signed Checks) ---
    
    s -> s + "define i64 @_str_cat(i64 %a, i64 %b) {" + NL^
    s -> s + "  %sa = inttoptr i64 %a to i8*" + NL^
    s -> s + "  %sb = inttoptr i64 %b to i8*" + NL^
    s -> s + "  %la = call i64 @strlen(i8* %sa)" + NL^
    s -> s + "  %lb = call i64 @strlen(i8* %sb)" + NL^
    s -> s + "  %sz = add i64 %la, %lb" + NL^
    s -> s + "  %sz1 = add i64 %sz, 1" + NL^
    s -> s + "  %mem = call i64 @malloc(i64 %sz1)" + NL^
    s -> s + "  %ptr = inttoptr i64 %mem to i8*" + NL^
    s -> s + "  call i8* @strcpy(i8* %ptr, i8* %sa)" + NL^
    s -> s + "  call i8* @strcat(i8* %ptr, i8* %sb)" + NL^
    s -> s + "  ret i64 %mem" + NL^
    s -> s + "}" + NL^

    s -> s + "define i64 @to_string(i64 %val) {" + NL^
    s -> s + "  %is_ptr = icmp sgt i64 %val, 4294967296" + NL^
    s -> s + "  br i1 %is_ptr, label %is_str, label %is_int" + NL^
    s -> s + "is_str: ret i64 %val" + NL^
    s -> s + "is_int:" + NL^
    s -> s + "  %mem = call i64 @malloc(i64 32)" + NL^
    s -> s + "  %p = inttoptr i64 %mem to i8*" + NL^
    s -> s + "  %fmt = getelementptr [4 x i8], [4 x i8]* @.fmt_raw_i, i64 0, i64 0" + NL^
    s -> s + "  call i32 (i8*, i8*, ...) @sprintf(i8* %p, i8* %fmt, i64 %val)" + NL^
    s -> s + "  ret i64 %mem" + NL^
    s -> s + "}" + NL^

    s -> s + "define i64 @_add(i64 %a, i64 %b) {" + NL^
    s -> s + "  %is_ptr_a = icmp sgt i64 %a, 4294967296" + NL^
    s -> s + "  %is_ptr_b = icmp sgt i64 %b, 4294967296" + NL^
    s -> s + "  %both_ptr = and i1 %is_ptr_a, %is_ptr_b" + NL^
    s -> s + "  %any_ptr = or i1 %is_ptr_a, %is_ptr_b" + NL^ // [FIX] If EITHER is a pointer
    s -> s + "  br i1 %both_ptr, label %check_list, label %check_str" + NL^
    s -> s + "check_list:" + NL^
    s -> s + "  %ptr_a = inttoptr i64 %a to i8*" + NL^
    s -> s + "  %type_a = load i8, i8* %ptr_a" + NL^
    s -> s + "  %is_list = icmp eq i8 %type_a, 3" + NL^
    s -> s + "  br i1 %is_list, label %do_list, label %check_str" + NL^
    s -> s + "check_str:" + NL^
    s -> s + "  br i1 %any_ptr, label %do_str, label %int" + NL^
    s -> s + "do_str:" + NL^
    s -> s + "  %sa = call i64 @to_string(i64 %a)" + NL^
    s -> s + "  %sb = call i64 @to_string(i64 %b)" + NL^
    s -> s + "  %ret_str = call i64 @_str_cat(i64 %sa, i64 %sb)" + NL^
    s -> s + "  ret i64 %ret_str" + NL^
    s -> s + "do_list:" + NL^
    s -> s + "  %new_list = call i64 @_list_new()" + NL^
    s -> s + "  call void @_list_copy(i64 %new_list, i64 %a)" + NL^
    s -> s + "  call void @_list_copy(i64 %new_list, i64 %b)" + NL^
    s -> s + "  ret i64 %new_list" + NL^
    s -> s + "int:" + NL^
    s -> s + "  %ret_int = add i64 %a, %b" + NL^
    s -> s + "  ret i64 %ret_int" + NL^
    s -> s + "}" + NL^

    // --- POLYMORPHIC APPEND HELPER ---
    s -> s + "define void @_list_copy(i64 %dest, i64 %src) {" + NL^
    s -> s + "  %ptr = inttoptr i64 %src to i64*" + NL^
    s -> s + "  %cnt_ptr = getelementptr i64, i64* %ptr, i64 1" + NL^
    s -> s + "  %cnt = load i64, i64* %cnt_ptr" + NL^
    s -> s + "  %data_ptr = getelementptr i64, i64* %ptr, i64 2" + NL^
    s -> s + "  %base = load i64, i64* %data_ptr" + NL^
    s -> s + "  %base_ptr = inttoptr i64 %base to i64*" + NL^
    s -> s + "  br label %loop" + NL^
    s -> s + "loop:" + NL^
    s -> s + "  %i = phi i64 [ 0, %0 ], [ %next_i, %body ]" + NL^
    s -> s + "  %cond = icmp slt i64 %i, %cnt" + NL^
    s -> s + "  br i1 %cond, label %body, label %done" + NL^
    s -> s + "body:" + NL^
    s -> s + "  %slot = getelementptr i64, i64* %base_ptr, i64 %i" + NL^
    s -> s + "  %val = load i64, i64* %slot" + NL^
    s -> s + "  call i64 @_list_push(i64 %dest, i64 %val)" + NL^
    s -> s + "  %next_i = add i64 %i, 1" + NL^
    s -> s + "  br label %loop" + NL^
    s -> s + "done:" + NL^
    s -> s + "  ret void" + NL^
    s -> s + "}" + NL^

    s -> s + "define i64 @_append_poly(i64 %list, i64 %val) {" + NL^
    s -> s + "  %is_ptr = icmp sgt i64 %val, 4294967296" + NL^
    s -> s + "  br i1 %is_ptr, label %check_list, label %push_one" + NL^
    s -> s + "check_list:" + NL^
    s -> s + "  %ptr = inttoptr i64 %val to i8*" + NL^
    s -> s + "  %type = load i8, i8* %ptr" + NL^
    s -> s + "  %is_list = icmp eq i8 %type, 3" + NL^
    s -> s + "  br i1 %is_list, label %merge, label %push_one" + NL^
    s -> s + "merge:" + NL^
    s -> s + "  call void @_list_copy(i64 %list, i64 %val)" + NL^
    s -> s + "  ret i64 0" + NL^
    s -> s + "push_one:" + NL^
    s -> s + "  call i64 @_list_push(i64 %list, i64 %val)" + NL^
    s -> s + "  ret i64 0" + NL^
    s -> s + "}" + NL^

    s -> s + "define i64 @_eq(i64 %a, i64 %b) {" + NL^
    // [FIX] Use sgt (Signed Greater Than) to handle -1 safely
    s -> s + "  %a_is_ptr = icmp sgt i64 %a, 4294967296" + NL^
    s -> s + "  %b_is_ptr = icmp sgt i64 %b, 4294967296" + NL^
    s -> s + "  %both_ptr = and i1 %a_is_ptr, %b_is_ptr" + NL^
    s -> s + "  br i1 %both_ptr, label %check_null, label %cmp_int" + NL^
    
    // Safety: Don't strcmp NULL (0)
    s -> s + "check_null:" + NL^
    s -> s + "  %a_null = icmp eq i64 %a, 0" + NL^
    s -> s + "  %b_null = icmp eq i64 %b, 0" + NL^
    s -> s + "  %any_null = or i1 %a_null, %b_null" + NL^
    s -> s + "  br i1 %any_null, label %cmp_int, label %cmp_str" + NL^

    s -> s + "cmp_str:" + NL^
    s -> s + "  %sa = inttoptr i64 %a to i8*" + NL^
    s -> s + "  %sb = inttoptr i64 %b to i8*" + NL^
    s -> s + "  %res = call i32 @strcmp(i8* %sa, i8* %sb)" + NL^
    s -> s + "  %iseq = icmp eq i32 %res, 0" + NL^
    s -> s + "  %ret_str = zext i1 %iseq to i64" + NL^
    s -> s + "  ret i64 %ret_str" + NL^
    s -> s + "cmp_int:" + NL^
    s -> s + "  %iseq_int = icmp eq i64 %a, %b" + NL^
    s -> s + "  %ret_int = zext i1 %iseq_int to i64" + NL^
    s -> s + "  ret i64 %ret_int" + NL^
    s -> s + "}" + NL^

    // --- COLLECTIONS ---
    s -> s + "define i64 @_list_new() {" + NL^
    s -> s + "  %mem = call i64 @malloc(i64 24)" + NL^
    s -> s + "  %ptr = inttoptr i64 %mem to i64*" + NL^
    s -> s + "  store i64 3, i64* %ptr" + NL^ 
    s -> s + "  %cnt = getelementptr i64, i64* %ptr, i64 1" + NL^
    s -> s + "  store i64 0, i64* %cnt" + NL^ 
    s -> s + "  %data = getelementptr i64, i64* %ptr, i64 2" + NL^
    s -> s + "  store i64 0, i64* %data" + NL^ 
    s -> s + "  ret i64 %mem" + NL^
    s -> s + "}" + NL^

    s -> s + "define i64 @_list_set(i64 %l, i64 %idx, i64 %v) {" + NL^
    s -> s + "  %ptr = inttoptr i64 %l to i64*" + NL^
    s -> s + "  %data_ptr = getelementptr i64, i64* %ptr, i64 2" + NL^
    s -> s + "  %base = load i64, i64* %data_ptr" + NL^
    s -> s + "  %base_ptr = inttoptr i64 %base to i64*" + NL^
    s -> s + "  %slot = getelementptr i64, i64* %base_ptr, i64 %idx" + NL^
    s -> s + "  store i64 %v, i64* %slot" + NL^
    s -> s + "  ret i64 0" + NL^
    s -> s + "}" + NL^


    s -> s + "define i64 @_list_push(i64 %l, i64 %v) {" + NL^
    s -> s + "  %ptr = inttoptr i64 %l to i64*" + NL^
    s -> s + "  %cnt_ptr = getelementptr i64, i64* %ptr, i64 1" + NL^
    s -> s + "  %cnt = load i64, i64* %cnt_ptr" + NL^
    s -> s + "  %new_cnt = add i64 %cnt, 1" + NL^
    s -> s + "  store i64 %new_cnt, i64* %cnt_ptr" + NL^
    s -> s + "  %data_ptr = getelementptr i64, i64* %ptr, i64 2" + NL^
    s -> s + "  %old_mem_i = load i64, i64* %data_ptr" + NL^
    
    // Scale memory exactly to what is needed (O(N) safe growth)
    s -> s + "  %req_bytes = mul i64 %new_cnt, 8" + NL^
    s -> s + "  %old_ptr = inttoptr i64 %old_mem_i to i8*" + NL^
    s -> s + "  %new_ptr = call i8* @realloc(i8* %old_ptr, i64 %req_bytes)" + NL^
    s -> s + "  %new_mem = ptrtoint i8* %new_ptr to i64" + NL^
    s -> s + "  store i64 %new_mem, i64* %data_ptr" + NL^
    
    s -> s + "  %base_ptr = inttoptr i64 %new_mem to i64*" + NL^
    s -> s + "  %idx = getelementptr i64, i64* %base_ptr, i64 %cnt" + NL^
    s -> s + "  store i64 %v, i64* %idx" + NL^
    s -> s + "  ret i64 0" + NL^
    s -> s + "}" + NL^

    s -> s + "define i64 @_map_new() {" + NL^
    s -> s + "  %m = call i64 @_list_new()" + NL^
    s -> s + "  %ptr = inttoptr i64 %m to i64*" + NL^
    s -> s + "  store i64 4, i64* %ptr" + NL^ 
    s -> s + "  ret i64 %m" + NL^
    s -> s + "}" + NL^

    s -> s + "define i64 @_map_set(i64 %m, i64 %k, i64 %v) {" + NL^
    s -> s + "  call i64 @_list_push(i64 %m, i64 %k)" + NL^
    s -> s + "  call i64 @_list_push(i64 %m, i64 %v)" + NL^
    s -> s + "  ret i64 0" + NL^
    s -> s + "}" + NL^

    // --- POLYMORPHIC SETTER ---
    s -> s + "define i64 @_set(i64 %col, i64 %idx, i64 %v) {" + NL^
    s -> s + "  %ptr = inttoptr i64 %col to i64*" + NL^
    s -> s + "  %type = load i64, i64* %ptr" + NL^
    s -> s + "  %is_map = icmp eq i64 %type, 4" + NL^
    s -> s + "  br i1 %is_map, label %do_map, label %do_list" + NL^
    s -> s + "do_list:" + NL^
    s -> s + "  call i64 @_list_set(i64 %col, i64 %idx, i64 %v)" + NL^
    s -> s + "  ret i64 0" + NL^
    s -> s + "do_map:" + NL^
    s -> s + "  call i64 @_map_set(i64 %col, i64 %idx, i64 %v)" + NL^
    s -> s + "  ret i64 0" + NL^
    s -> s + "}" + NL^

    // --- MAP LOOKUP ---
    // --- MAP LOOKUP (FIXED: Backwards search for updates) ---
    s -> s + "define i64 @_map_get(i64 %m, i64 %key) {" + NL^
    s -> s + "  %ptr = inttoptr i64 %m to i64*" + NL^
    s -> s + "  %cnt_ptr = getelementptr i64, i64* %ptr, i64 1" + NL^
    s -> s + "  %cnt = load i64, i64* %cnt_ptr" + NL^
    s -> s + "  %data_ptr = getelementptr i64, i64* %ptr, i64 2" + NL^
    s -> s + "  %base = load i64, i64* %data_ptr" + NL^
    s -> s + "  %base_ptr = inttoptr i64 %base to i64*" + NL^
    s -> s + "  %key_s = inttoptr i64 %key to i8*" + NL^
    
    // Start at end of list (cnt - 2)
    s -> s + "  %start_i = sub i64 %cnt, 2" + NL^
    s -> s + "  br label %loop" + NL^
    s -> s + "loop:" + NL^
    s -> s + "  %i = phi i64 [ %start_i, %0 ], [ %next_i, %next ]" + NL^
    s -> s + "  %cond = icmp sge i64 %i, 0" + NL^
    s -> s + "  br i1 %cond, label %check_key, label %not_found" + NL^
    
    s -> s + "check_key:" + NL^
    s -> s + "  %k_slot = getelementptr i64, i64* %base_ptr, i64 %i" + NL^
    s -> s + "  %k_val = load i64, i64* %k_slot" + NL^
    s -> s + "  %k_str = inttoptr i64 %k_val to i8*" + NL^
    s -> s + "  %cmp = call i32 @strcmp(i8* %k_str, i8* %key_s)" + NL^
    s -> s + "  %match = icmp eq i32 %cmp, 0" + NL^
    s -> s + "  br i1 %match, label %found, label %next" + NL^
    
    s -> s + "next:" + NL^
    s -> s + "  %next_i = sub i64 %i, 2" + NL^
    s -> s + "  br label %loop" + NL^
    
    s -> s + "found:" + NL^
    s -> s + "  %v_idx = add i64 %i, 1" + NL^
    s -> s + "  %v_slot = getelementptr i64, i64* %base_ptr, i64 %v_idx" + NL^
    s -> s + "  %ret = load i64, i64* %v_slot" + NL^
    s -> s + "  ret i64 %ret" + NL^
    
    s -> s + "not_found:" + NL^
    s -> s + "  ret i64 0" + NL^
    s -> s + "}" + NL^

    s -> s + "define i64 @_get(i64 %col, i64 %idx) {" + NL^
    s -> s + "  %is_null = icmp eq i64 %col, 0" + NL^
    s -> s + "  br i1 %is_null, label %err, label %check" + NL^
    s -> s + "check:" + NL^
    s -> s + "  %ptr8 = inttoptr i64 %col to i8*" + NL^
    s -> s + "  %tag = load i8, i8* %ptr8" + NL^
    s -> s + "  %is_list = icmp eq i8 %tag, 3" + NL^
    s -> s + "  br i1 %is_list, label %do_list, label %check_map" + NL^
    s -> s + "check_map:" + NL^
    s -> s + "  %is_map = icmp eq i8 %tag, 4" + NL^ // <-- FIXED
    s -> s + "  br i1 %is_map, label %do_map, label %do_str" + NL^
    s -> s + "do_str:" + NL^
    s -> s + "  %str_base = inttoptr i64 %col to i8*" + NL^
    s -> s + "  %char_ptr = getelementptr i8, i8* %str_base, i64 %idx" + NL^
    s -> s + "  %char = load i8, i8* %char_ptr" + NL^
    s -> s + "  %new_mem = call i64 @malloc(i64 2)" + NL^
    s -> s + "  %new_ptr = inttoptr i64 %new_mem to i8*" + NL^
    s -> s + "  store i8 %char, i8* %new_ptr" + NL^
    s -> s + "  %term = getelementptr i8, i8* %new_ptr, i64 1" + NL^
    s -> s + "  store i8 0, i8* %term" + NL^
    s -> s + "  %ret_str = ptrtoint i8* %new_ptr to i64" + NL^
    s -> s + "  ret i64 %ret_str" + NL^
    s -> s + "do_map:" + NL^
    s -> s + "  %map_val = call i64 @_map_get(i64 %col, i64 %idx)" + NL^
    s -> s + "  ret i64 %map_val" + NL^
    s -> s + "do_list:" + NL^
    s -> s + "  %ptr64 = inttoptr i64 %col to i64*" + NL^ // <-- EXPLICIT CAST
    s -> s + "  %data_ptr = getelementptr i64, i64* %ptr64, i64 2" + NL^
    s -> s + "  %base = load i64, i64* %data_ptr" + NL^
    s -> s + "  %arr = inttoptr i64 %base to i64*" + NL^
    s -> s + "  %slot = getelementptr i64, i64* %arr, i64 %idx" + NL^
    s -> s + "  %val = load i64, i64* %slot" + NL^
    s -> s + "  ret i64 %val" + NL^
    s -> s + "err: ret i64 0" + NL^
    s -> s + "}" + NL^

    s -> s + "define i64 @_get_argv(i64 %idx) {" + NL^
    s -> s + "  %argc = load i32, i32* @__sys_argc" + NL^
    s -> s + "  %argc64 = sext i32 %argc to i64" + NL^
    
    // Bounds check to prevent out-of-bounds argument crashing
    s -> s + "  %is_oob = icmp sge i64 %idx, %argc64" + NL^
    s -> s + "  br i1 %is_oob, label %err, label %ok" + NL^
    s -> s + "err:" + NL^
    s -> s + "  %emp = call i64 @malloc(i64 1)" + NL^
    s -> s + "  %emp_p = inttoptr i64 %emp to i8*" + NL^
    s -> s + "  store i8 0, i8* %emp_p" + NL^
    s -> s + "  ret i64 %emp" + NL^
    
    s -> s + "ok:" + NL^
    s -> s + "  %argv = load i8**, i8*** @__sys_argv" + NL^
    s -> s + "  %ptr = getelementptr i8*, i8** %argv, i64 %idx" + NL^
    s -> s + "  %str = load i8*, i8** %ptr" + NL^
    s -> s + "  %ret = ptrtoint i8* %str to i64" + NL^
    s -> s + "  ret i64 %ret" + NL^
    s -> s + "}" + NL^

    s -> s + "define i64 @revelare(i64 %path_i) {" + NL^
    s -> s + "  %path = inttoptr i64 %path_i to i8*" + NL^
    s -> s + "  %mode = getelementptr [2 x i8], [2 x i8]* @.mode_r, i64 0, i64 0" + NL^
    s -> s + "  %f = call i8* @fopen(i8* %path, i8* %mode)" + NL^
    s -> s + "  %f_int = ptrtoint i8* %f to i64" + NL^
    s -> s + "  %valid = icmp ne i64 %f_int, 0" + NL^
    s -> s + "  br i1 %valid, label %read, label %err" + NL^
    s -> s + "read:" + NL^
    s -> s + "  call i32 @fseek(i8* %f, i64 0, i32 2)" + NL^
    s -> s + "  %len = call i64 @ftell(i8* %f)" + NL^
    s -> s + "  call i32 @fseek(i8* %f, i64 0, i32 0)" + NL^
    s -> s + "  %alloc_sz = add i64 %len, 1" + NL^
    s -> s + "  %buf = call i64 @malloc(i64 %alloc_sz)" + NL^
    s -> s + "  %buf_ptr = inttoptr i64 %buf to i8*" + NL^
    s -> s + "  call i64 @fread(i8* %buf_ptr, i64 1, i64 %len, i8* %f)" + NL^
    s -> s + "  %term = getelementptr i8, i8* %buf_ptr, i64 %len" + NL^
    s -> s + "  store i8 0, i8* %term" + NL^
    s -> s + "  call i32 @fclose(i8* %f)" + NL^
    s -> s + "  ret i64 %buf" + NL^
    s -> s + "err:" + NL^
    s -> s + "  ret i64 0" + NL^
    s -> s + "}" + NL^

    s -> s + "define i64 @inscribo(i64 %path_i, i64 %content_i) {" + NL^
    s -> s + "  %path = inttoptr i64 %path_i to i8*" + NL^
    s -> s + "  %content = inttoptr i64 %content_i to i8*" + NL^
    s -> s + "  %mode = getelementptr [2 x i8], [2 x i8]* @.mode_w, i64 0, i64 0" + NL^
    s -> s + "  %f = call i8* @fopen(i8* %path, i8* %mode)" + NL^
    s -> s + "  %len = call i64 @strlen(i8* %content)" + NL^
    s -> s + "  call i64 @fwrite(i8* %content, i64 1, i64 %len, i8* %f)" + NL^
    s -> s + "  call i32 @fclose(i8* %f)" + NL^
    s -> s + "  ret i64 0" + NL^
    s -> s + "}" + NL^

    s -> s + "define i64 @print_any(i64 %val) {" + NL^
    s -> s + "entry:" + NL^
    s -> s + "  %is_ptr = icmp sgt i64 %val, 4294967296" + NL^
    s -> s + "  br i1 %is_ptr, label %check_obj, label %print_int" + NL^
    
    s -> s + "check_obj:" + NL^
    s -> s + "  %ptr8 = inttoptr i64 %val to i8*" + NL^
    s -> s + "  %tag = load i8, i8* %ptr8" + NL^
    s -> s + "  %is_list = icmp eq i8 %tag, 3" + NL^ 
    s -> s + "  br i1 %is_list, label %print_list, label %print_str" + NL^
    
    s -> s + "print_list:" + NL^
    s -> s + "  %f_s1 = getelementptr [3 x i8], [3 x i8]* @.fmt_raw_s, i64 0, i64 0" + NL^
    s -> s + "  %b_l = getelementptr [2 x i8], [2 x i8]* @.m_brk_l, i64 0, i64 0" + NL^
    s -> s + "  call i32 (i8*, ...) @printf(i8* %f_s1, i8* %b_l)" + NL^
    s -> s + "  call i32 @fflush(i8* null)" + NL^ 
    
    s -> s + "  %ptr64 = inttoptr i64 %val to i64*" + NL^ // <-- EXPLICIT CAST
    s -> s + "  %cnt_ptr = getelementptr i64, i64* %ptr64, i64 1" + NL^
    s -> s + "  %cnt = load i64, i64* %cnt_ptr" + NL^
    s -> s + "  %is_empty = icmp eq i64 %cnt, 0" + NL^
    s -> s + "  br i1 %is_empty, label %done, label %setup_loop" + NL^
    
    s -> s + "setup_loop:" + NL^
    s -> s + "  %data_ptr = getelementptr i64, i64* %ptr64, i64 2" + NL^
    s -> s + "  %base = load i64, i64* %data_ptr" + NL^
    s -> s + "  %base_ptr = inttoptr i64 %base to i64*" + NL^
    s -> s + "  br label %loop" + NL^
    
    s -> s + "loop:" + NL^
    s -> s + "  %i = phi i64 [ 0, %setup_loop ], [ %next_i, %loop_end ]" + NL^
    s -> s + "  %cond = icmp slt i64 %i, %cnt" + NL^
    s -> s + "  br i1 %cond, label %body, label %done" + NL^
    
    s -> s + "body:" + NL^
    s -> s + "  %not_first = icmp ne i64 %i, 0" + NL^
    s -> s + "  br i1 %not_first, label %comma, label %val_print" + NL^
    
    s -> s + "comma:" + NL^
    s -> s + "  %f_s2 = getelementptr [3 x i8], [3 x i8]* @.fmt_raw_s, i64 0, i64 0" + NL^
    s -> s + "  %com = getelementptr [3 x i8], [3 x i8]* @.m_comma, i64 0, i64 0" + NL^
    s -> s + "  call i32 (i8*, ...) @printf(i8* %f_s2, i8* %com)" + NL^
    s -> s + "  call i32 @fflush(i8* null)" + NL^ 
    s -> s + "  br label %val_print" + NL^
    
    s -> s + "val_print:" + NL^
    s -> s + "  %slot = getelementptr i64, i64* %base_ptr, i64 %i" + NL^
    s -> s + "  %v = load i64, i64* %slot" + NL^
    s -> s + "  %v_is_ptr = icmp sgt i64 %v, 4294967296" + NL^
    s -> s + "  br i1 %v_is_ptr, label %v_ptr_check, label %v_int" + NL^
    
    s -> s + "v_ptr_check:" + NL^
    s -> s + "  %vs_ptr8 = inttoptr i64 %v to i8*" + NL^ // <-- NESTED SEGFAULT FIX
    s -> s + "  %in_tag = load i8, i8* %vs_ptr8" + NL^
    s -> s + "  %in_is_list = icmp eq i8 %in_tag, 3" + NL^ 
    s -> s + "  br i1 %in_is_list, label %v_nested, label %v_raw_str" + NL^

    s -> s + "v_nested:" + NL^
    s -> s + "  call i64 @print_any(i64 %v)" + NL^ 
    s -> s + "  br label %loop_end" + NL^

    s -> s + "v_raw_str:" + NL^
    s -> s + "  %f_s3 = getelementptr [3 x i8], [3 x i8]* @.fmt_raw_s, i64 0, i64 0" + NL^
    s -> s + "  %vs_str = inttoptr i64 %v to i8*" + NL^
    s -> s + "  call i32 (i8*, ...) @printf(i8* %f_s3, i8* %vs_str)" + NL^
    s -> s + "  call i32 @fflush(i8* null)" + NL^ 
    s -> s + "  br label %loop_end" + NL^
    
    s -> s + "v_int:" + NL^
    s -> s + "  %f_i = getelementptr [4 x i8], [4 x i8]* @.fmt_raw_i, i64 0, i64 0" + NL^
    s -> s + "  call i32 (i8*, ...) @printf(i8* %f_i, i64 %v)" + NL^
    s -> s + "  call i32 @fflush(i8* null)" + NL^ 
    s -> s + "  br label %loop_end" + NL^
    
    s -> s + "loop_end:" + NL^
    s -> s + "  %next_i = add i64 %i, 1" + NL^
    s -> s + "  br label %loop" + NL^
    
    s -> s + "done:" + NL^
    s -> s + "  %f_s4 = getelementptr [3 x i8], [3 x i8]* @.fmt_raw_s, i64 0, i64 0" + NL^
    s -> s + "  %b_r = getelementptr [3 x i8], [3 x i8]* @.m_brk_r, i64 0, i64 0" + NL^
    s -> s + "  call i32 (i8*, ...) @printf(i8* %f_s4, i8* %b_r)" + NL^
    s -> s + "  call i32 @fflush(i8* null)" + NL^ 
    s -> s + "  ret i64 0" + NL^
    
    s -> s + "print_int:" + NL^
    s -> s + "  %f_i_end = getelementptr [5 x i8], [5 x i8]* @.fmt_int, i64 0, i64 0" + NL^
    s -> s + "  call i32 (i8*, ...) @printf(i8* %f_i_end, i64 %val)" + NL^
    s -> s + "  call i32 @fflush(i8* null)" + NL^ 
    s -> s + "  ret i64 0" + NL^
    
    s -> s + "print_str:" + NL^
    s -> s + "  %f_s_end = getelementptr [4 x i8], [4 x i8]* @.fmt_str, i64 0, i64 0" + NL^
    s -> s + "  %str_p = inttoptr i64 %val to i8*" + NL^
    s -> s + "  call i32 (i8*, ...) @printf(i8* %f_s_end, i8* %str_p)" + NL^
    s -> s + "  call i32 @fflush(i8* null)" + NL^ 
    s -> s + "  ret i64 0" + NL^
    s -> s + "}" + NL^

    s -> s + "define i64 @codex(i64 %val) {" + NL^
    s -> s + "  %ptr = inttoptr i64 %val to i8*" + NL^
    s -> s + "  %c = load i8, i8* %ptr" + NL^
    s -> s + "  %ret = zext i8 %c to i64" + NL^
    s -> s + "  ret i64 %ret" + NL^
    s -> s + "}" + NL^

    s -> s + "define i64 @pars(i64 %str, i64 %start, i64 %len) {" + NL^
    s -> s + "  %src = inttoptr i64 %str to i8*" + NL^
    s -> s + "  %slen = call i64 @strlen(i8* %src)" + NL^
    
    // Check if start is past EOF
    s -> s + "  %is_oob = icmp sge i64 %start, %slen" + NL^
    s -> s + "  br i1 %is_oob, label %oob, label %ok" + NL^
    s -> s + "oob:" + NL^
    s -> s + "  %emp = call i64 @malloc(i64 1)" + NL^
    s -> s + "  %emp_p = inttoptr i64 %emp to i8*" + NL^
    s -> s + "  store i8 0, i8* %emp_p" + NL^
    s -> s + "  ret i64 %emp" + NL^
    
    // Safely clamp length to prevent reading into unmapped hardware memory
    s -> s + "ok:" + NL^
    s -> s + "  %rem = sub i64 %slen, %start" + NL^
    s -> s + "  %is_long = icmp sgt i64 %len, %rem" + NL^
    s -> s + "  %safe_len = select i1 %is_long, i64 %rem, i64 %len" + NL^
    
    s -> s + "  %src_off = getelementptr i8, i8* %src, i64 %start" + NL^
    s -> s + "  %alloc_sz = add i64 %safe_len, 1" + NL^
    s -> s + "  %dest = call i64 @malloc(i64 %alloc_sz)" + NL^
    s -> s + "  %dest_ptr = inttoptr i64 %dest to i8*" + NL^
    s -> s + "  call i8* @strncpy(i8* %dest_ptr, i8* %src_off, i64 %safe_len)" + NL^
    s -> s + "  %term = getelementptr i8, i8* %dest_ptr, i64 %safe_len" + NL^
    s -> s + "  store i8 0, i8* %term" + NL^
    s -> s + "  ret i64 %dest" + NL^
    s -> s + "}" + NL^

    s -> s + "define i64 @signum_ex(i64 %val) {" + NL^
    s -> s + "  %mem = call i64 @malloc(i64 2)" + NL^
    s -> s + "  %ptr = inttoptr i64 %mem to i8*" + NL^
    s -> s + "  %c = trunc i64 %val to i8" + NL^
    s -> s + "  store i8 %c, i8* %ptr" + NL^
    s -> s + "  %term = getelementptr i8, i8* %ptr, i64 1" + NL^
    s -> s + "  store i8 0, i8* %term" + NL^
    s -> s + "  ret i64 %mem" + NL^
    s -> s + "}" + NL^

   s -> s + "define i64 @mensura(i64 %val) {" + NL^
    s -> s + "  %is_null = icmp eq i64 %val, 0" + NL^
    s -> s + "  br i1 %is_null, label %ret_zero, label %read" + NL^
    s -> s + "ret_zero:" + NL^
    s -> s + "  ret i64 0" + NL^
    s -> s + "read:" + NL^
    s -> s + "  %ptr8 = inttoptr i64 %val to i8*" + NL^
    s -> s + "  %type = load i8, i8* %ptr8" + NL^
    s -> s + "  %is_list = icmp eq i8 %type, 3" + NL^
    s -> s + "  %is_map = icmp eq i8 %type, 4" + NL^
    s -> s + "  %is_col = or i1 %is_list, %is_map" + NL^
    s -> s + "  br i1 %is_col, label %get_cnt, label %get_str" + NL^
    s -> s + "get_cnt:" + NL^
    s -> s + "  %ptr64 = inttoptr i64 %val to i64*" + NL^ // <-- EXPLICIT CAST
    s -> s + "  %cnt_ptr = getelementptr i64, i64* %ptr64, i64 1" + NL^
    s -> s + "  %cnt = load i64, i64* %cnt_ptr" + NL^
    s -> s + "  ret i64 %cnt" + NL^
    s -> s + "get_str:" + NL^
    s -> s + "  %str_ptr = inttoptr i64 %val to i8*" + NL^
    s -> s + "  %len = call i64 @strlen(i8* %str_ptr)" + NL^
    s -> s + "  ret i64 %len" + NL^
    s -> s + "}" + NL^

    // --- INPUT (Capio) ---
    s -> s + "define i64 @capio() {" + NL^
    // Allocate 256 bytes
    s -> s + "  %mem = call i64 @malloc(i64 256)" + NL^
    s -> s + "  %ptr = inttoptr i64 %mem to i8*" + NL^
    s -> s + "  br label %read" + NL^
    
    s -> s + "read:" + NL^
    s -> s + "  %i = phi i64 [ 0, %0 ], [ %next_i, %cont ]" + NL^
    s -> s + "  %c = call i32 @getchar()" + NL^
    
    // Stop on EOF (-1) or Newline (10)
    s -> s + "  %is_eof = icmp eq i32 %c, -1" + NL^
    s -> s + "  %is_nl = icmp eq i32 %c, 10" + NL^
    s -> s + "  %stop = or i1 %is_eof, %is_nl" + NL^
    s -> s + "  br i1 %stop, label %done, label %cont" + NL^
    
    s -> s + "cont:" + NL^
    s -> s + "  %char = trunc i32 %c to i8" + NL^
    s -> s + "  %slot = getelementptr i8, i8* %ptr, i64 %i" + NL^
    s -> s + "  store i8 %char, i8* %slot" + NL^
    s -> s + "  %next_i = add i64 %i, 1" + NL^
    
    // Safety buffer limit (255 chars)
    s -> s + "  %limit = icmp slt i64 %next_i, 255" + NL^
    s -> s + "  br i1 %limit, label %read, label %done" + NL^
    
    s -> s + "done:" + NL^
    // Null terminate
    s -> s + "  %term_slot = getelementptr i8, i8* %ptr, i64 %i" + NL^
    s -> s + "  store i8 0, i8* %term_slot" + NL^
    s -> s + "  ret i64 %mem" + NL^
    s -> s + "}" + NL^

    s -> s + "define i64 @imperium(i64 %cmd) {" + NL^
    s -> s + "  %p = inttoptr i64 %cmd to i8*" + NL^
    s -> s + "  %res = call i32 @system(i8* %p)" + NL^
    s -> s + "  %ext = sext i32 %res to i64" + NL^
    s -> s + "  ret i64 %ext" + NL^
    s -> s + "}" + NL^

    s -> s + "define i64 @dormire(i64 %ms) {" + NL^
    s -> s + "  %us = mul i64 %ms, 1000" + NL^
    s -> s + "  %us32 = trunc i64 %us to i32" + NL^
    s -> s + "  call i32 @usleep(i32 %us32)" + NL^
    s -> s + "  ret i64 0" + NL^
    s -> s + "}" + NL^

    s -> s + "define i64 @numerus(i64 %str) {" + NL^
    s -> s + "  %p = inttoptr i64 %str to i8*" + NL^
    s -> s + "  %res = call i64 @atol(i8* %p)" + NL^
    s -> s + "  ret i64 %res" + NL^
    s -> s + "}" + NL^

    s -> s + "define i64 @scindere(i64 %str, i64 %delim) {" + NL^
    s -> s + "  %list = call i64 @_list_new()" + NL^
    s -> s + "  %s_p = inttoptr i64 %str to i8*" + NL^
    s -> s + "  %d_p = inttoptr i64 %delim to i8*" + NL^
    s -> s + "  %len = call i64 @strlen(i8* %s_p)" + NL^
    s -> s + "  %sz = add i64 %len, 1" + NL^
    s -> s + "  %mem = call i64 @malloc(i64 %sz)" + NL^
    s -> s + "  %cp = inttoptr i64 %mem to i8*" + NL^
    s -> s + "  call i8* @strcpy(i8* %cp, i8* %s_p)" + NL^
    s -> s + "  %tok = call i8* @strtok(i8* %cp, i8* %d_p)" + NL^
    s -> s + "  br label %loop" + NL^
    s -> s + "loop:" + NL^
    s -> s + "  %curr = phi i8* [ %tok, %0 ], [ %nxt, %body ]" + NL^
    s -> s + "  %is_null = icmp eq i8* %curr, null" + NL^
    s -> s + "  br i1 %is_null, label %done, label %body" + NL^
    s -> s + "body:" + NL^
    s -> s + "  %t_val = ptrtoint i8* %curr to i64" + NL^
    s -> s + "  call i64 @_list_push(i64 %list, i64 %t_val)" + NL^
    s -> s + "  %nxt = call i8* @strtok(i8* null, i8* %d_p)" + NL^
    s -> s + "  br label %loop" + NL^
    s -> s + "done:" + NL^
    s -> s + "  ret i64 %list" + NL^
    s -> s + "}" + NL^

    s -> s + "define i64 @iunctura(i64 %list_ptr, i64 %delim) {" + NL^
    s -> s + "  %is_null = icmp eq i64 %list_ptr, 0" + NL^
    s -> s + "  br i1 %is_null, label %ret_empty, label %check" + NL^
    s -> s + "check:" + NL^
    s -> s + "  %ptr64 = inttoptr i64 %list_ptr to i64*" + NL^
    s -> s + "  %cnt_ptr = getelementptr i64, i64* %ptr64, i64 1" + NL^
    s -> s + "  %cnt = load i64, i64* %cnt_ptr" + NL^
    s -> s + "  %is_empty = icmp eq i64 %cnt, 0" + NL^
    s -> s + "  br i1 %is_empty, label %ret_empty, label %calc" + NL^
    s -> s + "ret_empty:" + NL^
    s -> s + "  %emp = call i64 @malloc(i64 1)" + NL^
    s -> s + "  %emp_p = inttoptr i64 %emp to i8*" + NL^
    s -> s + "  store i8 0, i8* %emp_p" + NL^
    s -> s + "  ret i64 %emp" + NL^
    s -> s + "calc:" + NL^
    s -> s + "  %data_ptr = getelementptr i64, i64* %ptr64, i64 2" + NL^
    s -> s + "  %base = load i64, i64* %data_ptr" + NL^
    s -> s + "  %base_ptr = inttoptr i64 %base to i64*" + NL^
    s -> s + "  %res_0 = call i64 @malloc(i64 1)" + NL^
    s -> s + "  %res_0_p = inttoptr i64 %res_0 to i8*" + NL^
    s -> s + "  store i8 0, i8* %res_0_p" + NL^
    s -> s + "  br label %loop" + NL^
    s -> s + "loop:" + NL^
    s -> s + "  %i = phi i64 [ 0, %calc ], [ %next_i, %merge ]" + NL^
    s -> s + "  %curr_str = phi i64 [ %res_0, %calc ], [ %next_str, %merge ]" + NL^
    s -> s + "  %cond = icmp slt i64 %i, %cnt" + NL^
    s -> s + "  br i1 %cond, label %body, label %done" + NL^
    s -> s + "body:" + NL^
    s -> s + "  %slot = getelementptr i64, i64* %base_ptr, i64 %i" + NL^
    s -> s + "  %item = load i64, i64* %slot" + NL^
    s -> s + "  %item_s = call i64 @to_string(i64 %item)" + NL^
    s -> s + "  %added = call i64 @_str_cat(i64 %curr_str, i64 %item_s)" + NL^
    s -> s + "  %last_idx = sub i64 %cnt, 1" + NL^
    s -> s + "  %is_last = icmp eq i64 %i, %last_idx" + NL^
    s -> s + "  br i1 %is_last, label %skip_delim, label %add_delim" + NL^
    s -> s + "add_delim:" + NL^
    s -> s + "  %with_delim = call i64 @_str_cat(i64 %added, i64 %delim)" + NL^
    s -> s + "  br label %merge" + NL^
    s -> s + "skip_delim:" + NL^
    s -> s + "  br label %merge" + NL^
    s -> s + "merge:" + NL^
    s -> s + "  %next_str = phi i64 [ %with_delim, %add_delim ], [ %added, %skip_delim ]" + NL^
    s -> s + "  %next_i = add i64 %i, 1" + NL^
    s -> s + "  br label %loop" + NL^
    s -> s + "done:" + NL^
    s -> s + "  ret i64 %curr_str" + NL^
    s -> s + "}" + NL^

    

    // ==========================================
    // --- ACHLYS BARE-METAL OS LAYER ---
    // ==========================================

    // The God Gateway: x86_64 Linux Inline Assembly Syscalls
    s -> s + "define i64 @syscall6(i64 %sys_no, i64 %a1, i64 %a2, i64 %a3, i64 %a4, i64 %a5, i64 %a6) {" + NL^
    s -> s + "  %res = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},{rsi},{rdx},{r10},{r8},{r9},~{rcx},~{r11},~{memory}\"(i64 %sys_no, i64 %a1, i64 %a2, i64 %a3, i64 %a4, i64 %a5, i64 %a6)" + NL^
    s -> s + "  ret i64 %res" + NL^
    s -> s + "}" + NL^

    // Pure Native String Library (Zero C Dependency)
    s -> s + "define i64 @strlen(i8* %str) {" + NL^
    s -> s + "entry: br label %loop" + NL^
    s -> s + "loop:" + NL^
    s -> s + "  %i = phi i64 [ 0, %entry ], [ %nxt, %loop ]" + NL^
    s -> s + "  %ptr = getelementptr i8, i8* %str, i64 %i" + NL^
    s -> s + "  %c = load i8, i8* %ptr" + NL^
    s -> s + "  %is_null = icmp eq i8 %c, 0" + NL^
    s -> s + "  %nxt = add i64 %i, 1" + NL^
    s -> s + "  br i1 %is_null, label %done, label %loop" + NL^
    s -> s + "done: ret i64 %i" + NL^
    s -> s + "}" + NL^

    s -> s + "define i32 @strcmp(i8* %s1, i8* %s2) {" + NL^
    s -> s + "entry: br label %loop" + NL^
    s -> s + "loop:" + NL^
    s -> s + "  %i = phi i64 [ 0, %entry ], [ %nxt, %loop ]" + NL^
    s -> s + "  %p1 = getelementptr i8, i8* %s1, i64 %i" + NL^
    s -> s + "  %p2 = getelementptr i8, i8* %s2, i64 %i" + NL^
    s -> s + "  %c1 = load i8, i8* %p1" + NL^
    s -> s + "  %c2 = load i8, i8* %p2" + NL^
    s -> s + "  %not_eq = icmp ne i8 %c1, %c2" + NL^
    s -> s + "  %is_null = icmp eq i8 %c1, 0" + NL^
    s -> s + "  %stop = or i1 %not_eq, %is_null" + NL^
    s -> s + "  %nxt = add i64 %i, 1" + NL^
    s -> s + "  br i1 %stop, label %done, label %loop" + NL^
    s -> s + "done:" + NL^
    s -> s + "  %z1 = zext i8 %c1 to i32" + NL^
    s -> s + "  %z2 = zext i8 %c2 to i32" + NL^
    s -> s + "  %diff = sub i32 %z1, %z2" + NL^
    s -> s + "  ret i32 %diff" + NL^
    s -> s + "}" + NL^

    s -> s + "define i8* @strcpy(i8* %dest, i8* %src) {" + NL^
    s -> s + "entry: br label %loop" + NL^
    s -> s + "loop:" + NL^
    s -> s + "  %i = phi i64 [ 0, %entry ], [ %nxt, %loop ]" + NL^
    s -> s + "  %ps = getelementptr i8, i8* %src, i64 %i" + NL^
    s -> s + "  %pd = getelementptr i8, i8* %dest, i64 %i" + NL^
    s -> s + "  %c = load i8, i8* %ps" + NL^
    s -> s + "  store i8 %c, i8* %pd" + NL^
    s -> s + "  %is_null = icmp eq i8 %c, 0" + NL^
    s -> s + "  %nxt = add i64 %i, 1" + NL^
    s -> s + "  br i1 %is_null, label %done, label %loop" + NL^
    s -> s + "done: ret i8* %dest" + NL^
    s -> s + "}" + NL^

    s -> s + "define i8* @strncpy(i8* %dest, i8* %src, i64 %n) {" + NL^
    s -> s + "entry: br label %loop" + NL^
    s -> s + "loop:" + NL^
    s -> s + "  %i = phi i64 [ 0, %entry ], [ %nxt, %body ]" + NL^
    s -> s + "  %cmp = icmp slt i64 %i, %n" + NL^
    s -> s + "  br i1 %cmp, label %body, label %done" + NL^
    s -> s + "body:" + NL^
    s -> s + "  %ps = getelementptr i8, i8* %src, i64 %i" + NL^
    s -> s + "  %pd = getelementptr i8, i8* %dest, i64 %i" + NL^
    s -> s + "  %c = load i8, i8* %ps" + NL^
    s -> s + "  store i8 %c, i8* %pd" + NL^
    s -> s + "  %nxt = add i64 %i, 1" + NL^
    s -> s + "  br label %loop" + NL^
    s -> s + "done: ret i8* %dest" + NL^
    s -> s + "}" + NL^

    s -> s + "define i8* @strcat(i8* %dest, i8* %src) {" + NL^
    s -> s + "  %len = call i64 @strlen(i8* %dest)" + NL^
    s -> s + "  %d_end = getelementptr i8, i8* %dest, i64 %len" + NL^
    s -> s + "  call i8* @strcpy(i8* %d_end, i8* %src)" + NL^
    s -> s + "  ret i8* %dest" + NL^
    s -> s + "}" + NL^

    reddo s^
}

// ============================================================================
// [SECTION 7] MAIN
// ============================================================================
opus expand_imports(stmts) {
    vas expanded : arr -> []^
    vas i : int -> 0^
    dum (i < mensura(stmts)) {
        vas s : obj -> stmts[i]^
        si (s["type"] == STMT_IMPORT) { // [FIX] Replaced hardcoded 220
            vas path : str -> s["val"]["val"]^
            vas src : str -> revelare(path)^
            si (mensura(src) > 0) {
                vas old_toks : arr -> global_tokens^
                vas old_pos : int -> p_pos^
                global_tokens -> lex_source(src)^
                p_pos -> 0^
                vas imp_stmts : arr -> []^
                dum (peek()["type"] != 0) {
                    si (peek()["type"] == 29) { advance()^ }
                    aliter { imp_stmts << parse_stmt()^ }
                }
                vas sub_exp : arr -> expand_imports(imp_stmts)^
                vas j : int -> 0^
                dum (j < mensura(sub_exp)) { expanded << sub_exp[j]^ j -> j + 1^ }
                global_tokens -> old_toks^
                p_pos -> old_pos^
            } aliter { scribo("💀 FATAL LINKER ERROR: Could not read " + path)^ }
        } aliter { expanded << s^ }
        i -> i + 1^
    }
    reddo expanded^
}
// ============================================================================
// [SECTION 7] MAIN (LLVM DRIVER - GLOBAL AWARE)
// ============================================================================

opus main() {
    scribo("⚔️  ACHLYS -> LLVM COMPILER (STAGE 3.5)")^
    
    init_constants()^
    global_tokens -> []^
    p_pos -> 0^
    
    vas arg : str -> capere_argumentum(1)^
    vas filename : str -> ""^
    vas valid : int -> 1^

    si (mensura(arg) == 0) {
        scribo("Usage: ./achlys <file.nox>")^
        valid -> 0^
    } aliter { filename -> arg^ }

    si (valid) {
        vas src : str -> revelare(filename)^
        
        si (mensura(src) == 0) {
            scribo("⚠️  File not found: " + filename)^
        } aliter {
            scribo("[1/3] Lexing...")^
            global_tokens -> lex_source(src)^
            vas token_count : int -> mensura(global_tokens)^
            scribo("[DEBUG] Main sees " + int_to_str(token_count) + " tokens.")^
            
            vas k : int -> 0^
            dum (k < token_count) {
                vas t : obj -> global_tokens[k]^
                scribo(" T[" + int_to_str(k) + "]: " + t["text"] + " (" + int_to_str(t["type"]) + ")")^
                k -> k + 1^
            }
            
            scribo("[2/3] Parsing...")^
            use_huge_lists -> 1^
            vas stmts : arr -> []^
            use_huge_lists -> 0^
            
            vas pt : obj -> peek()^
            dum (pt["type"] != TOK_EOF) {
                si (has_error) { abrumpere^ }
                si (pt["type"] == TOK_CARET) { advance()^ pergere^ }
                stmts << parse_stmt()^
                pt -> peek()^
            }
            
            // [FIX] Expand imports AFTER parsing the main file!
            vas flat_stmts : arr -> expand_imports(stmts)^
            
            si (has_error) {
                scribo("❌ Compilation Failed.")^
            } aliter {
                scribo("[3/3] Generating LLVM IR...")^
          
                vas header : str -> get_llvm_header()^
                vas top_level : arr -> []^
                vas i : int -> 0^
                
                // [FIX] Iterate over flat_stmts, not stmts!
                dum (i < mensura(flat_stmts)) {
                    vas s : obj -> flat_stmts[i]^
                    
                    // 1. FUNCTIONS
                    si (s["type"] == STMT_FUNC) {
                        compile_func(s)^ 
                    } 
                    // 2. GLOBALS (Shared/Const/Let at top level)
                    aliter { si (s["type"] == STMT_SHARED vel s["type"] == STMT_CONST) {
                         // Define Global: @name = global i64 0
                         vas g_name : str -> "@" + s["name"]^
                         out_data -> out_data + g_name + " = global i64 0" + signum_ex(10)^
                         global_map[s["name"]] -> g_name^
                         
                         // Convert Declaration to Assignment for @main execution
                         // communis x -> 10  becomes  x = 10 inside @main
                         vas assign : obj -> { "type": STMT_ASSIGN, "name": s["name"], "val": s["val"] }^
                         top_level << assign^
                    } 
                    // 3. TOP LEVEL CODE
                    aliter {
                         top_level << s^
                    } }
                    i -> i + 1^
                }
                
                // GENERATE @main
                vas NL : str -> signum_ex(10)^
                emit_raw("define i32 @main(i32 %argc, i8** %argv) {")^
                emit_raw("  store i32 %argc, i32* @__sys_argc")^
                emit_raw("  store i8** %argv, i8*** @__sys_argv")^
                
                vas boot_msg : str -> add_global_string(">> EXECUTING <<")^
                emit_raw("  %boot_msg_ptr = getelementptr [22 x i8], [22 x i8]* " + boot_msg + ", i64 0, i64 0")^
                emit_raw("  %boot_msg_int = ptrtoint i8* %boot_msg_ptr to i64")^
                emit_raw("  call i64 @print_any(i64 %boot_msg_int)")^

                reg_count -> 0^
                var_map -> {}^
                
                // [DEBUG] Check statement count
                scribo("[DEBUG] Top Level Statements: " + int_to_str(mensura(top_level)))^

                i -> 0^
                dum (i < mensura(top_level)) {
                    compile_stmt(top_level[i])^
                    i -> i + 1^
                }
                
                emit("ret i32 0")^
                emit_raw("}")^
                
                vas final_ir : str -> header + out_data + out_code^
                inscribo("kernel.ll", final_ir)^
                scribo("✅ SUCCESS. 'kernel.ll' generated.")^
            }
        }
    }
}

main()^